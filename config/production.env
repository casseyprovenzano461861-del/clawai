# ClawAI 生产环境配置文件
# 请根据实际环境修改以下配置

# ====================
# 基础配置
# ====================
DEBUG=false
SECRET_KEY=clawai-production-secret-key-change-this-in-production

# ====================
# API密钥配置
# ====================
# DeepSeek API密钥（必需）
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# OpenAI API密钥（可选）
OPENAI_API_KEY=

# Claude API密钥（可选）
CLAUDE_API_KEY=

# ====================
# 服务器配置
# ====================
SERVER_HOST=0.0.0.0
BACKEND_PORT=5000
FRONTEND_PORT=3000

# ====================
# 安全配置
# ====================
API_AUTH_ENABLED=true
API_SECRET_KEY=your-production-api-secret-key-change-this
JWT_SECRET=your-production-jwt-secret-change-this
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# 默认管理员账户（首次启动时创建）
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin@clawai123

# ====================
# 数据库配置
# ====================
DATABASE_TYPE=sqlite
DATABASE_URL=sqlite:////app/clawai.db

# 如果需要MySQL/PostgreSQL：
# DATABASE_TYPE=mysql
# DATABASE_URL=mysql://username:password@host:port/database_name
# DATABASE_TYPE=postgresql
# DATABASE_URL=postgresql://username:password@host:port/database_name

# ====================
# 日志配置
# ====================
LOG_LEVEL=INFO
LOG_FILE=/app/logs/clawai.log
LOG_MAX_SIZE=10485760  # 10MB
LOG_BACKUP_COUNT=5

# ====================
# 功能开关
# ====================
ENABLE_REAL_ATTACK=true
ENABLE_CVE_DETECTION=true
ENABLE_AI_ANALYSIS=true
ENABLE_ATTACK_VISUALIZATION=true
ENABLE_ATTACK_EVOLUTION=true
ENABLE_DEFENSE_SIMULATION=true
ENABLE_REPORT_GENERATION=true

# ====================
# 性能配置
# ====================
MAX_WORKERS=10
REQUEST_TIMEOUT=300  # 5分钟
TOOL_EXECUTION_TIMEOUT=180  # 3分钟
AI_REQUEST_TIMEOUT=60  # 1分钟
CACHE_ENABLED=true
CACHE_TTL=3600  # 1小时

# ====================
# 工具配置
# ====================
# 安全工具路径（如果已安装在主机上）
NMAP_PATH=/usr/bin/nmap
WHATWEB_PATH=/usr/bin/whatweb
NUCLEI_PATH=/usr/local/bin/nuclei

# ====================
# 网络配置
# ====================
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60  # 秒

# ====================
# 监控配置
# ====================
ENABLE_METRICS=true
METRICS_PORT=9090
HEALTH_CHECK_INTERVAL=30  # 秒

# ====================
# 部署模式
# ====================
DEPLOYMENT_MODE=production
USE_MOCK_DATA=false
DEVELOPMENT_MODE=false

# ====================
# 邮件配置（可选）
# ====================
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# ADMIN_EMAIL=admin@example.com

# ====================
# 备份配置
# ====================
BACKUP_ENABLED=true
BACKUP_INTERVAL=86400  # 24小时
BACKUP_RETENTION_DAYS=7