# ClawAI 配置文件示例
# 复制此文件为 config.yaml 并根据需要修改

# 应用配置
environment: development  # development, testing, staging, production
project_name: "ClawAI"
project_version: "2.0.0"
project_description: "智能安全评估系统"

# 服务器配置
server:
  host: "0.0.0.0"
  port: 8000
  workers: 1
  reload: true
  log_level: info

# 数据库配置
database:
  type: sqlite  # sqlite, postgresql, mysql, mongodb
  url: "sqlite:///./clawai.db"
  pool_size: 5
  max_overflow: 10
  echo: false

# 安全配置
security:
  secret_key: "your-secret-key-change-this-in-production"
  jwt_secret: "your-jwt-secret-change-this-in-production"
  jwt_algorithm: "HS256"
  jwt_expiration_hours: 24
  api_auth_enabled: true
  enable_real_attack: false
  mfa_enabled: false
  cors_origins:
    - "http://localhost:3000"
    - "http://localhost:8000"

# 缓存配置
cache:
  type: memory  # memory, redis, filesystem
  default_timeout: 300
  redis_host: "localhost"
  redis_port: 6379
  redis_password: null
  redis_db: 0

# LLM配置
llm:
  provider: openai  # openai, anthropic, azure_openai, local, mock
  api_key: ""  # 在此处填入您的API密钥
  model: "gpt-4"
  base_url: null  # 自定义API端点
  temperature: 0.7
  max_tokens: 2000
  timeout: 60

# 工具配置
tool:
  timeout: 30
  max_concurrent_tools: 5
  use_docker: true
  tools_dir: "./tools/penetration"
  auto_install: false

# 日志配置
logging:
  level: info  # debug, info, warning, error, critical
  file: "./logs/clawai.log"
  max_size: 10485760  # 10MB
  backup_count: 5
  format: "%(asctime)s - %(name)s - %(levelname)s - %(message)s"

