import React, { useState, useEffect, useRef } from 'react';
import {
  Network, Database, Shield, User, Server, Globe, Lock, Unlock,
  AlertTriangle, CheckCircle, XCircle, Search, Filter, Download,
  ZoomIn, ZoomOut, RefreshCw, Settings, Layers, Link, Target,
  BarChart3, PieChart, LineChart, Hash, Cpu, Wifi, Key, Eye
} from 'lucide-react';

// 导入设计系统组件
import Card from './design-system/Card';
import Button from './design-system/Button';
import Badge from './design-system/Badge';
import Alert from './design-system/Alert';

const KnowledgeGraph = () => {
  const [loading, setLoading] = useState(true);
  const [graphData, setGraphData] = useState(null);
  const [selectedNode, setSelectedNode] = useState(null);
  const [selectedEdge, setSelectedEdge] = useState(null);
  const [searchTerm, setSearchTerm] = useState('');
  const [filterType, setFilterType] = useState('all');
  const [zoomLevel, setZoomLevel] = useState(1);
  const [viewMode, setViewMode] = useState('force');
  const [showDetails, setShowDetails] = useState(false);
  const [graphStats, setGraphStats] = useState({});
  const canvasRef = useRef(null);

  // 模拟知识图谱数据
  const mockGraphData = {
    nodes: [
      { id: 'target-1', label: '目标服务器', type: 'server', x: 300, y: 200, size: 40, color: '#3b82f6', 
        properties: { ip: '192.168.1.100', os: 'Linux', ports: '22,80,443', status: '在线', risk: '中' } },
      { id: 'vuln-1', label: 'SQL注入漏洞', type: 'vulnerability', x: 500, y: 150, size: 35, color: '#ef4444',
        properties: { cve: 'CVE-2024-1234', severity: '高危', cvss: 8.5, exploit: '可用', patch: '未修复' } },
      { id: 'vuln-2', label: 'XSS漏洞', type: 'vulnerability', x: 500, y: 250, size: 30, color: '#f59e0b',
        properties: { cve: 'CVE-2024-5678', severity: '中危', cvss: 6.2, exploit: '可用', patch: '已修复' } },
      { id: 'user-1', label: '管理员账户', type: 'user', x: 100, y: 200, size: 35, color: '#10b981',
        properties: { username: 'admin', role: '管理员', lastLogin: '2026-04-05', status: '活跃' } },
      { id: 'tool-1', label: 'NMAP扫描器', type: 'tool', x: 100, y: 300, size: 30, color: '#8b5cf6',
        properties: { tool: 'nmap', version: '7.94', findings: 15, success: true } },
      { id: 'network-1', label: '内部网络', type: 'network', x: 300, y: 400, size: 45, color: '#6366f1',
        properties: { subnet: '192.168.1.0/24', devices: 24, services: 8, security: '中等' } },
      { id: 'attack-1', label: '攻击路径', type: 'attack', x: 500, y: 350, size: 35, color: '#ec4899',
        properties: { steps: 3, complexity: '中等', successRate: '75%', impact: '数据泄露' } },
      { id: 'asset-1', label: '数据库服务器', type: 'asset', x: 700, y: 200, size: 40, color: '#14b8a6',
        properties: { type: 'MySQL', version: '8.0', data: '敏感', backup: '有' } },
      { id: 'threat-1', label: 'APT组织', type: 'threat', x: 700, y: 350, size: 38, color: '#f97316',
        properties: { name: 'APT29', country: '未知', targets: '政府,企业', techniques: 12 } },
      { id: 'defense-1', label: 'WAF防护', type: 'defense', x: 300, y: 100, size: 32, color: '#22c55e',
        properties: { vendor: 'Cloudflare', rules: 245, blocked: 1245, effectiveness: '高' } },
    ],
    edges: [
      { id: 'edge-1', source: 'tool-1', target: 'target-1', label: '扫描发现', type: 'discovery', strength: 0.9 },
      { id: 'edge-2', source: 'target-1', target: 'vuln-1', label: '存在漏洞', type: 'has_vulnerability', strength: 0.8 },
      { id: 'edge-3', source: 'target-1', target: 'vuln-2', label: '存在漏洞', type: 'has_vulnerability', strength: 0.6 },
      { id: 'edge-4', source: 'user-1', target: 'target-1', label: '访问权限', type: 'has_access', strength: 0.7 },
      { id: 'edge-5', source: 'vuln-1', target: 'asset-1', label: '可访问', type: 'can_access', strength: 0.9 },
      { id: 'edge-6', source: 'vuln-2', target: 'asset-1', label: '可访问', type: 'can_access', strength: 0.5 },
      { id: 'edge-7', source: 'attack-1', target: 'vuln-1', label: '利用漏洞', type: 'exploits', strength: 0.8 },
      { id: 'edge-8', source: 'attack-1', target: 'vuln-2', label: '利用漏洞', type: 'exploits', strength: 0.4 },
      { id: 'edge-9', source: 'threat-1', target: 'attack-1', label: '使用攻击', type: 'uses', strength: 0.7 },
      { id: 'edge-10', source: 'network-1', target: 'target-1', label: '包含主机', type: 'contains', strength: 1.0 },
      { id: 'edge-11', source: 'defense-1', target: 'target-1', label: '保护', type: 'protects', strength: 0.8 },
      { id: 'edge-12', source: 'defense-1', target: 'vuln-1', label: '检测', type: 'detects', strength: 0.6 },
      { id: 'edge-13', source: 'defense-1', target: 'vuln-2', label: '阻止', type: 'blocks', strength: 0.9 },
    ]
  };

  // 节点类型配置
  const nodeTypes = {
    server: { icon: Server, color: '#3b82f6', name: '服务器' },
    vulnerability: { icon: AlertTriangle, color: '#ef4444', name: '漏洞' },
    user: { icon: User, color: '#10b981', name: '用户' },
    tool: { icon: Cpu, color: '#8b5cf6', name: '工具' },
    network: { icon: Wifi, color: '#6366f1', name: '网络' },
    attack: { icon: Target, color: '#ec4899', name: '攻击' },
    asset: { icon: Database, color: '#14b8a6', name: '资产' },
    threat: { icon: Shield, color: '#f97316', name: '威胁' },
    defense: { icon: Lock, color: '#22c55e', name: '防御' }
  };

  // 边类型配置
  const edgeTypes = {
    discovery: { color: '#8b5cf6', name: '发现' },
    has_vulnerability: { color: '#ef4444', name: '存在漏洞' },
    has_access: { color: '#10b981', name: '访问权限' },
    can_access: { color: '#f59e0b', name: '可访问' },
    exploits: { color: '#ec4899', name: '利用' },
    uses: { color: '#f97316', name: '使用' },
    contains: { color: '#6366f1', name: '包含' },
    protects: { color: '#22c55e', name: '保护' },
    detects: { color: '#3b82f6', name: '检测' },
    blocks: { color: '#14b8a6', name: '阻止' }
  };

  useEffect(() => {
    // 从API获取知识图谱数据
    const fetchGraphData = async () => {
      try {
        setLoading(true);
        const response = await fetch('http://localhost:8000/api/v1/knowledge-graph/graph');
        if (!response.ok) {
          throw new Error(`HTTP error! status: ${response.status}`);
        }
        const result = await response.json();
        
        if (result.success && result.data) {
          // 转换API数据格式为前端需要的格式
          const transformedData = {
            nodes: result.data.nodes.map(node => ({
              id: node.id,
              label: node.label,
              type: node.type,
              x: node.position?.x || Math.random() * 800,
              y: node.position?.y || Math.random() * 600,
              size: node.size || 35,
              color: node.color || '#3b82f6',
              properties: node.properties || {}
            })),
            edges: result.data.edges.map(edge => ({
              id: edge.id,
              source: edge.source,
              target: edge.target,
              label: edge.label,
              type: edge.type,
              strength: 0.8,
              color: edge.color || '#94a3b8'
            }))
          };
          
          setGraphData(transformedData);
          
          // 计算统计信息
          const stats = {
            totalNodes: transformedData.nodes.length,
            totalEdges: transformedData.edges.length,
            nodeTypes: {},
            edgeTypes: {},
            riskLevels: {
              high: transformedData.nodes.filter(n => n.type === 'vulnerability' && n.properties?.severity === '高危').length,
              medium: transformedData.nodes.filter(n => n.type === 'vulnerability' && n.properties?.severity === '中危').length,
              low: transformedData.nodes.filter(n => n.type === 'vulnerability' && n.properties?.severity === '低危').length
            }
          };
          
          // 统计节点类型
          transformedData.nodes.forEach(node => {
            stats.nodeTypes[node.type] = (stats.nodeTypes[node.type] || 0) + 1;
          });
          
          // 统计边类型
          transformedData.edges.forEach(edge => {
            stats.edgeTypes[edge.type] = (stats.edgeTypes[edge.type] || 0) + 1;
          });
          
          setGraphStats(stats);
        } else {
          // 如果API失败，使用模拟数据作为后备
          console.warn('API返回数据格式不正确，使用模拟数据');
          setGraphData(mockGraphData);
          
          const stats = {
            totalNodes: mockGraphData.nodes.length,
            totalEdges: mockGraphData.edges.length,
            nodeTypes: {},
            edgeTypes: {},
            riskLevels: {
              high: mockGraphData.nodes.filter(n => n.type === 'vulnerability' && n.properties?.severity === '高危').length,
              medium: mockGraphData.nodes.filter(n => n.type === 'vulnerability' && n.properties?.severity === '中危').length,
              low: mockGraphData.nodes.filter(n => n.type === 'vulnerability' && n.properties?.severity === '低危').length
            }
          };
          
          mockGraphData.nodes.forEach(node => {
            stats.nodeTypes[node.type] = (stats.nodeTypes[node.type] || 0) + 1;
          });
          
          mockGraphData.edges.forEach(edge => {
            stats.edgeTypes[edge.type] = (stats.edgeTypes[edge.type] || 0) + 1;
          });
          
          setGraphStats(stats);
        }
      } catch (error) {
        console.error('获取知识图谱数据失败:', error);
        // 使用模拟数据作为后备
        setGraphData(mockGraphData);
        
        const stats = {
          totalNodes: mockGraphData.nodes.length,
          totalEdges: mockGraphData.edges.length,
          nodeTypes: {},
          edgeTypes: {},
          riskLevels: {
            high: mockGraphData.nodes.filter(n => n.type === 'vulnerability' && n.properties?.severity === '高危').length,
            medium: mockGraphData.nodes.filter(n => n.type === 'vulnerability' && n.properties?.severity === '中危').length,
            low: mockGraphData.nodes.filter(n => n.type === 'vulnerability' && n.properties?.severity === '低危').length
          }
        };
        
        mockGraphData.nodes.forEach(node => {
          stats.nodeTypes[node.type] = (stats.nodeTypes[node.type] || 0) + 1;
        });
        
        mockGraphData.edges.forEach(edge => {
          stats.edgeTypes[edge.type] = (stats.edgeTypes[edge.type] || 0) + 1;
        });
        
        setGraphStats(stats);
      } finally {
        setLoading(false);
        // 初始化Canvas绘图
        const canvas = canvasRef.current;
        if (canvas) {
          const ctx = canvas.getContext('2d');
          drawGraph(ctx);
        }
      }
    };
    
    fetchGraphData();
  }, []);

  const drawGraph = (ctx) => {
    if (!graphData || !ctx) return;

    const canvas = canvasRef.current;
    if (!canvas) return;

    // 清除画布
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    // 绘制边
    graphData.edges.forEach(edge => {
      const sourceNode = graphData.nodes.find(n => n.id === edge.source);
      const targetNode = graphData.nodes.find(n => n.id === edge.target);
      
      if (!sourceNode || !targetNode) return;

      const edgeType = edgeTypes[edge.type];
      if (!edgeType) return;

      // 计算位置（考虑缩放）
      const sx = sourceNode.x * zoomLevel;
      const sy = sourceNode.y * zoomLevel;
      const tx = targetNode.x * zoomLevel;
      const ty = targetNode.y * zoomLevel;

      // 绘制边
      ctx.beginPath();
      ctx.moveTo(sx, sy);
      ctx.lineTo(tx, ty);
      ctx.strokeStyle = edgeType.color;
      ctx.lineWidth = 2 + edge.strength * 3;
      ctx.stroke();

      // 绘制箭头
      drawArrow(ctx, sx, sy, tx, ty, edgeType.color);
    });

    // 绘制节点
    graphData.nodes.forEach(node => {
      const nodeType = nodeTypes[node.type];
      if (!nodeType) return;

      const x = node.x * zoomLevel;
      const y = node.y * zoomLevel;
      const size = node.size * zoomLevel;

      // 绘制节点
      ctx.beginPath();
      ctx.arc(x, y, size, 0, Math.PI * 2);
      ctx.fillStyle = node.color;
      ctx.fill();
      ctx.strokeStyle = '#ffffff';
      ctx.lineWidth = 2;
      ctx.stroke();

      // 绘制图标
      const Icon = nodeType.icon;
      // 这里可以添加图标绘制逻辑

      // 绘制标签
      ctx.fillStyle = '#ffffff';
      ctx.font = '12px Arial';
      ctx.textAlign = 'center';
      ctx.fillText(node.label, x, y + size + 15);
    });
  };

  const drawArrow = (ctx, fromX, fromY, toX, toY, color) => {
    const headlen = 10;
    const dx = toX - fromX;
    const dy = toY - fromY;
    const angle = Math.atan2(dy, dx);

    ctx.save();
    ctx.strokeStyle = color;
    ctx.fillStyle = color;

    // 绘制箭头
    ctx.beginPath();
    ctx.moveTo(toX, toY);
    ctx.lineTo(toX - headlen * Math.cos(angle - Math.PI / 6), toY - headlen * Math.sin(angle - Math.PI / 6));
    ctx.moveTo(toX, toY);
    ctx.lineTo(toX - headlen * Math.cos(angle + Math.PI / 6), toY - headlen * Math.sin(angle + Math.PI / 6));
    ctx.stroke();
    ctx.restore();
  };

  const handleNodeClick = (node) => {
    setSelectedNode(node);
    setSelectedEdge(null);
    setShowDetails(true);
  };

  const handleEdgeClick = (edge) => {
    setSelectedEdge(edge);
    setSelectedNode(null);
    setShowDetails(true);
  };

  const handleZoomIn = () => {
    setZoomLevel(prev => Math.min(prev + 0.1, 2));
  };

  const handleZoomOut = () => {
    setZoomLevel(prev => Math.max(prev - 0.1, 0.5));
  };

  const handleResetView = () => {
    setZoomLevel(1);
  };

  const filteredNodes = graphData ? graphData.nodes.filter(node => {
    if (filterType !== 'all' && node.type !== filterType) return false;
    if (searchTerm && !node.label.toLowerCase().includes(searchTerm.toLowerCase())) return false;
    return true;
  }) : [];

  const filteredEdges = graphData ? graphData.edges.filter(edge => {
    if (filterType !== 'all') {
      const sourceNode = graphData.nodes.find(n => n.id === edge.source);
      const targetNode = graphData.nodes.find(n => n.id === edge.target);
      if (!sourceNode || !targetNode) return false;
      if (sourceNode.type !== filterType && targetNode.type !== filterType) return false;
    }
    if (searchTerm) {
      const sourceNode = graphData.nodes.find(n => n.id === edge.source);
      const targetNode = graphData.nodes.find(n => n.id === edge.target);
      if (!sourceNode || !targetNode) return false;
      if (!sourceNode.label.toLowerCase().includes(searchTerm.toLowerCase()) && 
          !targetNode.label.toLowerCase().includes(searchTerm.toLowerCase())) return false;
    }
    return true;
  }) : [];

  const StatCard = ({ icon: Icon, title, value, color = 'blue', change }) => {
    const colorClasses = {
      blue: 'text-blue-500',
      green: 'text-green-500',
      red: 'text-red-500',
      purple: 'text-purple-500',
      orange: 'text-orange-500',
      indigo: 'text-indigo-500',
      yellow: 'text-yellow-500',
      pink: 'text-pink-500'
    };

    return (
      <Card className="p-4">
        <div className="flex items-center justify-between mb-3">
          <div className={`p-2 rounded-lg ${colorClasses[color]}/10`}>
            <Icon className={`w-5 h-5 ${colorClasses[color]}`} />
          </div>
          {change && (
            <Badge variant={change > 0 ? 'success' : 'danger'} size="sm">
              {change > 0 ? '+' : ''}{change}
            </Badge>
          )}
        </div>
        <div className="text-2xl font-bold mb-1">{value}</div>
        <div className="text-sm opacity-70">{title}</div>
      </Card>
    );
  };

  if (loading) {
    return (
      <div className="flex items-center justify-center h-64">
        <div className="text-center">
          <div className="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-500 mx-auto"></div>
          <p className="mt-4 text-gray-400">加载知识图谱数据...</p>
        </div>
      </div>
    );
  }

  return (
    <div className="min-h-screen bg-gray-900 text-white">
      {/* 知识图谱头部 */}
      <div className="bg-gray-800/80 backdrop-blur-sm border-b border-gray-700 sticky top-0 z-50">
        <div className="container mx-auto px-6 py-4">
          <div className="flex flex-col md:flex-row items-start md:items-center justify-between">
            <div>
              <h1 className="text-2xl font-bold">知识图谱系统</h1>
              <p className="text-gray-400 mt-1">基于PentAGI Graphiti架构的安全实体关系可视化</p>
            </div>
            
            <div className="flex items-center space-x-3 mt-4 md:mt-0">
              <Button
                variant="outline"
                className="flex items-center"
              >
                <Download className="w-4 h-4 mr-2" />
                导出图谱
              </Button>
              
              <Button
                variant="primary"
                className="flex items-center"
              >
                <RefreshCw className="w-4 h-4 mr-2" />
                重新分析
              </Button>
            </div>
          </div>
        </div>
      </div>

      <div className="container mx-auto px-6 py-8">
        {/* 统计卡片 */}
        <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-6 mb-8">
          <StatCard 
            icon={Network}
            title="总节点数"
            value={graphStats.totalNodes || 0}
            change={3}
            color="blue"
          />
          <StatCard 
            icon={Link}
            title="总关系数"
            value={graphStats.totalEdges || 0}
            change={5}
            color="green"
          />
          <StatCard 
            icon={AlertTriangle}
            title="高危漏洞"
            value={graphStats.riskLevels?.high || 0}
            change={-1}
            color="red"
          />
          <StatCard 
            icon={Shield}
            title="防御节点"
            value={graphStats.nodeTypes?.defense || 0}
            change={2}
            color="purple"
          />
          <StatCard 
            icon={Database}
            title="资产节点"
            value={graphStats.nodeTypes?.asset || 0}
            change={1}
            color="indigo"
          />
        </div>

        {/* 控制面板 */}
        <Card className="mb-8">
          <div className="flex flex-col md:flex-row items-center justify-between p-4">
            <div className="flex flex-col md:flex-row items-center space-y-4 md:space-y-0 md:space-x-4 mb-4 md:mb-0">
              {/* 搜索框 */}
              <div className="relative">
                <Search className="absolute left-3 top-1/2 transform -translate-y-1/2 w-4 h-4 opacity-50" />
                <input
                  type="text"
                  placeholder="搜索节点或关系..."
                  value={searchTerm}
                  onChange={(e) => setSearchTerm(e.target.value)}
                  className="pl-10 pr-4 py-2 bg-gray-800 border border-gray-700 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 w-64"
                />
              </div>

              {/* 类型过滤 */}
              <select
                value={filterType}
                onChange={(e) => setFilterType(e.target.value)}
                className="px-4 py-2 bg-gray-800 border border-gray-700 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
              >
                <option value="all">所有类型</option>
                <option value="server">服务器</option>
                <option value="vulnerability">漏洞</option>
                <option value="user">用户</option>
                <option value="tool">工具</option>
                <option value="network">网络</option>
                <option value="attack">攻击</option>
                <option value="asset">资产</option>
                <option value="threat">威胁</option>
                <option value="defense">防御</option>
              </select>

              {/* 视图模式 */}
              <select
                value={viewMode}
                onChange={(e) => setViewMode(e.target.value)}
                className="px-4 py-2 bg-gray-800 border border-gray-700 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
              >
                <option value="force">力导向图</option>
                <option value="hierarchical">层次图</option>
                <option value="radial">放射图</option>
                <option value="circular">环形图</option>
              </select>
            </div>

            <div className="flex items-center space-x-2">
              <Button
                variant="ghost"
                size="sm"
                onClick={handleZoomOut}
                className="flex items-center"
              >
                <ZoomOut className="w-4 h-4 mr-2" />
                缩小
              </Button>
              
              <Button
                variant="ghost"
                size="sm"
                onClick={handleResetView}
                className="flex items-center"
              >
                <RefreshCw className="w-4 h-4 mr-2" />
                重置
              </Button>
              
              <Button
                variant="ghost"
                size="sm"
                onClick={handleZoomIn}
                className="flex items-center"
              >
                <ZoomIn className="w-4 h-4 mr-2" />
                放大
              </Button>
              
              <Button
                variant="ghost"
                size="sm"
                className="flex items-center"
              >
                <Settings className="w-4 h-4 mr-2" />
                设置
              </Button>
            </div>
          </div>
        </Card>

        {/* 主内容区域 */}
        <div className="grid grid-cols-1 lg:grid-cols-3 gap-8">
          {/* 图谱可视化区域 */}
          <div className="lg:col-span-2">
            <Card className="p-4 h-[600px] relative">
              <div className="absolute top-4 right-4 z-10">
                <Badge variant="info" size="sm">
                  缩放: {zoomLevel.toFixed(1)}x
                </Badge>
              </div>
              
              <canvas
                ref={canvasRef}
                width={800}
                height={560}
                className="w-full h-full rounded-lg bg-gray-800/50 border border-gray-700"
                onClick={(e) => {
                  // 简单的点击检测（实际项目中需要更精确的检测）
                  const rect = e.target.getBoundingClientRect();
                  const x = (e.clientX - rect.left) / zoomLevel;
                  const y = (e.clientY - rect.top) / zoomLevel;
                  
                  // 查找点击的节点
                  const clickedNode = graphData.nodes.find(node => {
                    const distance = Math.sqrt(
                      Math.pow(node.x - x, 2) + Math.pow(node.y - y, 2)
                    );
                    return distance < node.size;
                  });
                  
                  if (clickedNode) {
                    handleNodeClick(clickedNode);
                  } else {
                    setSelectedNode(null);
                    setSelectedEdge(null);
                  }
                }}
              />
              
              <div className="mt-4 flex items-center justify-between">
                <div className="flex items-center space-x-4">
                  <div className="flex items-center">
                    <div className="w-3 h-3 rounded-full bg-blue-500 mr-2"></div>
                    <span className="text-sm">服务器</span>
                  </div>
                  <div className="flex items-center">
                    <div className="w-3 h-3 rounded-full bg-red-500 mr-2"></div>
                    <span className="text-sm">漏洞</span>
                  </div>
                  <div className="flex items-center">
                    <div className="w-3 h-3 rounded-full bg-green-500 mr-2"></div>
                    <span className="text-sm">用户</span>
                  </div>
                  <div className="flex items-center">
                    <div className="w-3 h-3 rounded-full bg-purple-500 mr-2"></div>
                    <span className="text-sm">工具</span>
                  </div>
                </div>
                
                <div className="text-sm text-gray-400">
                  显示 {filteredNodes.length} 个节点, {filteredEdges.length} 条关系
                </div>
              </div>
            </Card>
          </div>

          {/* 侧边栏 */}
          <div className="space-y-6">
            {/* 节点列表 */}
            <Card>
              <div className="flex items-center mb-4">
                <Layers className="w-5 h-5 text-blue-400 mr-2" />
                <h2 className="text-lg font-semibold">节点列表</h2>
              </div>
              
              <div className="space-y-2 max-h-64 overflow-y-auto">
                {filteredNodes.map(node => {
                  const nodeType = nodeTypes[node.type];
                  return (
                    <div
                      key={node.id}
                      className={`p-3 rounded-lg cursor-pointer transition-colors ${
                        selectedNode?.id === node.id 
                          ? 'bg-blue-500/20 border border-blue-500/30' 
                          : 'bg-gray-800/50 hover:bg-gray-700/50'
                      }`}
                      onClick={() => handleNodeClick(node)}
                    >
                      <div className="flex items-center justify-between">
                        <div className="flex items-center">
                          <div 
                            className="w-3 h-3 rounded-full mr-3"
                            style={{ backgroundColor: node.color }}
                          ></div>
                          <span className="font-medium">{node.label}</span>
                        </div>
                        <Badge variant="outline" size="xs">
                          {nodeType?.name || node.type}
                        </Badge>
                      </div>
                      <div className="text-sm text-gray-400 mt-1">
                        {Object.entries(node.properties || {}).slice(0, 2).map(([key, value]) => (
                          <span key={key} className="mr-3">
                            {key}: <span className="text-gray-300">{value}</span>
                          </span>
                        ))}
                      </div>
                    </div>
                  );
                })}
              </div>
            </Card>

            {/* 关系列表 */}
            <Card>
              <div className="flex items-center mb-4">
                <Link className="w-5 h-5 text-green-400 mr-2" />
                <h2 className="text-lg font-semibold">关系列表</h2>
              </div>
              
              <div className="space-y-2 max-h-64 overflow-y-auto">
                {filteredEdges.map(edge => {
                  const edgeType = edgeTypes[edge.type];
                  const sourceNode = graphData.nodes.find(n => n.id === edge.source);
                  const targetNode = graphData.nodes.find(n => n.id === edge.target);
                  
                  return (
                    <div
                      key={edge.id}
                      className={`p-3 rounded-lg cursor-pointer transition-colors ${
                        selectedEdge?.id === edge.id 
                          ? 'bg-green-500/20 border border-green-500/30' 
                          : 'bg-gray-800/50 hover:bg-gray-700/50'
                      }`}
                      onClick={() => handleEdgeClick(edge)}
                    >
                      <div className="flex items-center justify-between">
                        <div className="flex items-center">
                          <div 
                            className="w-3 h-3 rounded-full mr-3"
                            style={{ backgroundColor: edgeType?.color || '#6b7280' }}
                          ></div>
                          <span className="font-medium">{edge.label}</span>
                        </div>
                        <Badge variant="outline" size="xs">
                          强度: {(edge.strength * 100).toFixed(0)}%
                        </Badge>
                      </div>
                      <div className="text-sm text-gray-400 mt-1">
                        {sourceNode?.label} → {targetNode?.label}
                      </div>
                    </div>
                  );
                })}
              </div>
            </Card>

            {/* 快速操作 */}
            <Card>
              <div className="flex items-center mb-4">
                <Settings className="w-5 h-5 text-purple-400 mr-2" />
                <h2 className="text-lg font-semibold">快速操作</h2>
              </div>
              
              <div className="grid grid-cols-2 gap-2">
                <Button variant="outline" size="sm" fullWidth className="flex items-center justify-center">
                  <Eye className="w-4 h-4 mr-2" />
                  高亮路径
                </Button>
                <Button variant="outline" size="sm" fullWidth className="flex items-center justify-center">
                  <Filter className="w-4 h-4 mr-2" />
                  过滤风险
                </Button>
                <Button variant="outline" size="sm" fullWidth className="flex items-center justify-center">
                  <BarChart3 className="w-4 h-4 mr-2" />
                  分析统计
                </Button>
                <Button variant="outline" size="sm" fullWidth className="flex items-center justify-center">
                  <Download className="w-4 h-4 mr-2" />
                  导出数据
                </Button>
              </div>
            </Card>
          </div>
        </div>

        {/* 详情面板 */}
        {showDetails && (selectedNode || selectedEdge) && (
          <div className="mt-8">
            <Card>
              <div className="flex items-center justify-between mb-6">
                <h2 className="text-xl font-semibold">
                  {selectedNode ? '节点详情' : '关系详情'}
                </h2>
                <button 
                  onClick={() => setShowDetails(false)}
                  className="text-gray-400 hover:text-white"
                >
                  ✕
                </button>
              </div>
              
              {selectedNode && (
                <div className="space-y-6">
                  <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                      <label className="block text-sm font-medium mb-2">节点ID</label>
                      <div className="px-4 py-2 bg-gray-700 rounded-lg">{selectedNode.id}</div>
                    </div>
                    
                    <div>
                      <label className="block text-sm font-medium mb-2">节点类型</label>
                      <div className="px-4 py-2 bg-gray-700 rounded-lg">
                        <Badge variant="info" size="sm">
                          {nodeTypes[selectedNode.type]?.name || selectedNode.type}
                        </Badge>
                      </div>
                    </div>
                    
                    <div>
                      <label className="block text-sm font-medium mb-2">标签</label>
                      <div className="px-4 py-2 bg-gray-700 rounded-lg">{selectedNode.label}</div>
                    </div>
                    
                    <div>
                      <label className="block text-sm font-medium mb-2">颜色</label>
                      <div className="flex items-center">
                        <div 
                          className="w-6 h-6 rounded-full mr-3"
                          style={{ backgroundColor: selectedNode.color }}
                        ></div>
                        <span>{selectedNode.color}</span>
                      </div>
                    </div>
                  </div>
                  
                  <div>
                    <h3 className="font-medium mb-3">属性</h3>
                    <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
                      {Object.entries(selectedNode.properties || {}).map(([key, value]) => (
                        <div key={key} className="p-3 rounded-lg bg-gray-800/50">
                          <div className="text-sm opacity-70 mb-1">{key}</div>
                          <div className="font-medium">{value}</div>
                        </div>
                      ))}
                    </div>
                  </div>
                  
                  <div>
                    <h3 className="font-medium mb-3">相关关系</h3>
                    <div className="flex flex-wrap gap-2">
                      {graphData.edges
                        .filter(edge => edge.source === selectedNode.id || edge.target === selectedNode.id)
                        .map(edge => {
                          const edgeType = edgeTypes[edge.type];
                          const otherNodeId = edge.source === selectedNode.id ? edge.target : edge.source;
                          const otherNode = graphData.nodes.find(n => n.id === otherNodeId);
                          
                          return (
                            <Badge 
                              key={edge.id} 
                              variant="outline" 
                              size="sm"
                              className="cursor-pointer hover:bg-gray-700"
                              onClick={() => {
                                const edgeObj = graphData.edges.find(e => e.id === edge.id);
                                if (edgeObj) handleEdgeClick(edgeObj);
                              }}
                            >
                              {edge.label}: {otherNode?.label}
                            </Badge>
                          );
                        })}
                    </div>
                  </div>
                </div>
              )}
              
              {selectedEdge && (
                <div className="space-y-6">
                  <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                      <label className="block text-sm font-medium mb-2">关系ID</label>
                      <div className="px-4 py-2 bg-gray-700 rounded-lg">{selectedEdge.id}</div>
                    </div>
                    
                    <div>
                      <label className="block text-sm font-medium mb-2">关系类型</label>
                      <div className="px-4 py-2 bg-gray-700 rounded-lg">
                        <Badge variant="info" size="sm">
                          {edgeTypes[selectedEdge.type]?.name || selectedEdge.type}
                        </Badge>
                      </div>
                    </div>
                    
                    <div>
                      <label className="block text-sm font-medium mb-2">标签</label>
                      <div className="px-4 py-2 bg-gray-700 rounded-lg">{selectedEdge.label}</div>
                    </div>
                    
                    <div>
                      <label className="block text-sm font-medium mb-2">强度</label>
                      <div className="px-4 py-2 bg-gray-700 rounded-lg">
                        {(selectedEdge.strength * 100).toFixed(0)}%
                      </div>
                    </div>
                  </div>
                  
                  <div>
                    <h3 className="font-medium mb-3">连接节点</h3>
                    <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                      <div className="p-4 rounded-lg bg-gray-800/50">
                        <div className="text-sm opacity-70 mb-2">源节点</div>
                        <div className="flex items-center">
                          <div 
                            className="w-4 h-4 rounded-full mr-3"
                            style={{ 
                              backgroundColor: graphData.nodes.find(n => n.id === selectedEdge.source)?.color || '#6b7280' 
                            }}
                          ></div>
                          <div>
                            <div className="font-medium">
                              {graphData.nodes.find(n => n.id === selectedEdge.source)?.label}
                            </div>
                            <div className="text-sm text-gray-400">
                              {graphData.nodes.find(n => n.id === selectedEdge.source)?.type}
                            </div>
                          </div>
                        </div>
                      </div>
                      
                      <div className="p-4 rounded-lg bg-gray-800/50">
                        <div className="text-sm opacity-70 mb-2">目标节点</div>
                        <div className="flex items-center">
                          <div 
                            className="w-4 h-4 rounded-full mr-3"
                            style={{ 
                              backgroundColor: graphData.nodes.find(n => n.id === selectedEdge.target)?.color || '#6b7280' 
                            }}
                          ></div>
                          <div>
                            <div className="font-medium">
                              {graphData.nodes.find(n => n.id === selectedEdge.target)?.label}
                            </div>
                            <div className="text-sm text-gray-400">
                              {graphData.nodes.find(n => n.id === selectedEdge.target)?.type}
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                  
                  <div className="flex justify-end space-x-3 pt-4">
                    <Button
                      variant="outline"
                      onClick={() => setShowDetails(false)}
                    >
                      关闭
                    </Button>
                    <Button
                      variant="primary"
                      onClick={() => {
                        // 高亮显示相关节点和边
                        alert(`高亮显示关系: ${selectedEdge.label}`);
                      }}
                    >
                      高亮显示
                    </Button>
                  </div>
                </div>
              )}
            </Card>
          </div>
        )}
      </div>

      {/* 底部信息栏 */}
      <div className="mt-12 py-6 border-t border-gray-800">
        <div className="container mx-auto px-6">
          <div className="flex flex-col md:flex-row items-center justify-between">
            <div className="mb-4 md:mb-0">
              <div className="flex items-center space-x-2">
                <Network className="w-5 h-5 text-blue-500" />
                <span className="font-medium">ClawAI 知识图谱系统</span>
              </div>
              <div className="text-sm text-gray-400 mt-1">
                基于PentAGI Graphiti架构 | 版本 1.0 | 支持安全实体关系可视化
              </div>
            </div>
            <div className="flex items-center space-x-4 text-sm">
              <span className="text-gray-400">状态: <span className="text-green-500">● 知识图谱正常</span></span>
              <span className="text-gray-400">节点数: <span className="font-medium">{graphStats.totalNodes || 0}</span></span>
              <span className="text-gray-400">关系数: <span className="font-medium">{graphStats.totalEdges || 0}</span></span>
              <button className="text-blue-400 hover:text-blue-300">
                知识图谱文档
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  );
};

export default KnowledgeGraph;
