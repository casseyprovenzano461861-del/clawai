        raise HTTPException(
            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
            detail=f"LLM攻击计划生成失败: {str(e)}"
        )


@app.post("/api/v1/llm/plan-and-execute")
async def llm_plan_and_execute(
    request_data: Dict[str, Any],
    llm_integrator: LLMAgentIntegrator = Depends(get_llm_integrator)
):
    """完整的LLM计划-执行工作流"""
    try:
        target = request_data.get("target", "")
        config_name = request_data.get("config_name", "clawai_pentest_agent")
        initial_scan_results = request_data.get("scan_results", {})
        available_skills = request_data.get("available_skills")
        max_iterations = request_data.get("max_iterations")

        if not target:
            raise HTTPException(
                status_code=status.HTTP_400_BAD_REQUEST,
                detail="必须提供目标地址"
            )

        workflow_result = await llm_integrator.run_pentest_workflow(
            target=target,
            config_name=config_name,
            initial_scan_results=initial_scan_results,
            available_skills=available_skills,
            max_iterations=max_iterations
        )

        logger.info(f"LLM计划-执行工作流完成: {target}, {len(workflow_result.get('iterations', []))} 次迭代")
        return workflow_result

    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"LLM计划-执行工作流失败: {e}")
        raise HTTPException(
            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
            detail=f"LLM计划-执行工作流失败: {str(e)}"
        )


