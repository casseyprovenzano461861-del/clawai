@app.post("/api/v1/ai/generate-plan")
async def generate_attack_plan(request_data: Dict[str, Any]):
    """生成攻击计划（兼容旧版）"""
    if not service_state["initialized"]:
        raise HTTPException(
            status_code=status.HTTP_503_SERVICE_UNAVAILABLE,
            detail="AI引擎服务未初始化"
        )

    try:
        target = request_data.get("target", "")
        scan_results = request_data.get("scan_results", {})
        goal = request_data.get("goal", "get_shell")
        style = request_data.get("style", "balanced")

        if not target:
            raise HTTPException(
                status_code=status.HTTP_400_BAD_REQUEST,
                detail="必须提供目标地址"
            )

        # 使用决策引擎生成攻击路径（旧版逻辑）
        decision_engine = app.state.decision_engine

        # 模拟攻击路径数据
        attack_paths = [
            {
                "path_id": 1,
                "name": "全面Web应用攻击",
                "strategy": "Web应用渗透测试",
                "steps": [
                    {"step": 1, "tool": "nmap", "description": "端口扫描"},
                    {"step": 2, "tool": "whatweb", "description": "技术栈识别"},
                    {"step": 3, "tool": "nuclei", "description": "漏洞扫描"},
                    {"step": 4, "tool": "sqlmap", "description": "SQL注入检测"}
                ],
                "target_focus": "Web服务",
                "difficulty": "medium",
                "estimated_time": "12分钟",
                "success_rate": 0.75
            },
            {
                "path_id": 2,
                "name": "快速Web安全评估",
                "strategy": "快速安全扫描",
                "steps": [
                    {"step": 1, "tool": "nmap", "description": "快速端口扫描"},
                    {"step": 2, "tool": "whatweb", "description": "基础技术栈识别"}
                ],
                "target_focus": "Web服务",
                "difficulty": "easy",
                "estimated_time": "6分钟",
                "success_rate": 0.85
            }
        ]

        # 使用决策引擎评分和选择
        result = decision_engine.process_paths(attack_paths, scan_results)

        plan = {
            "target": target,
            "goal": goal,
            "style": style,
            "generated_at": time.time(),
            "selected_plan": result.get("best_path"),
            "all_options": result.get("all_scores", []),
            "confidence": result.get("confidence", 0.0),
            "reason": result.get("reason", "")
        }

        logger.info(f"攻击计划生成完成: {target} -> {plan['selected_plan']['path_info']['name'] if plan['selected_plan'] else '无'}")
        return plan

    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"攻击计划生成失败: {e}")
        raise HTTPException(
            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
            detail=f"攻击计划生成失败: {str(e)}"
        )


@app.post("/api/v1/ai/execute-skill")
async def execute_skill(request_data: Dict[str, Any]):
    """执行特定技能（兼容旧版）"""
    if not service_state["initialized"]:
        raise HTTPException(
            status_code=status.HTTP_503_SERVICE_UNAVAILABLE,
            detail="AI引擎服务未初始化"
        )

    try:
        skill_name = request_data.get("skill_name", "")
        target = request_data.get("target", "")
        context = request_data.get("context", {})

        if not skill_name or not target:
            raise HTTPException(
                status_code=status.HTTP_400_BAD_REQUEST,
                detail="必须提供技能名称和目标地址"
            )

        # 获取技能注册表
        skill_registry = app.state.skill_registry
        skill = skill_registry.get_skill(skill_name)

        if not skill:
            raise HTTPException(
                status_code=status.HTTP_404_NOT_FOUND,
                detail=f"技能 {skill_name} 未找到"
            )

        # 执行技能
        result = skill.execute(context)

        logger.info(f"技能执行完成: {skill_name} -> {target}")
        return {
            "skill": skill_name,
            "target": target,
            "executed_at": time.time(),
            "result": result
        }

    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"技能执行失败: {e}")
        raise HTTPException(
            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
            detail=f"技能执行失败: {str(e)}"
        )


@app.get("/api/v1/skills")
async def get_available_skills():
    """获取可用技能列表（兼容旧版）"""
    if not service_state["initialized"]:
        raise HTTPException(
            status_code=status.HTTP_503_SERVICE_UNAVAILABLE,
            detail="AI引擎服务未初始化"
        )

    try:
        skill_registry = app.state.skill_registry
        skills = skill_registry.get_all_skills()

        skill_list = []
        for skill in skills:
            skill_list.append({
                "name": skill.name,
                "description": skill.description,
                "category": skill.category,
                "difficulty": skill.difficulty,
                "success_rate": skill.success_rate,
                "estimated_time": skill.estimated_time
            })

        return {
            "skills": skill_list,
            "count": len(skill_list),
            "timestamp": time.time()
        }

    except Exception as e:
        logger.error(f"获取技能列表失败: {e}")
        raise HTTPException(
            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
            detail=f"获取技能列表失败: {str(e)}"
        )


# ========== 配置管理API ==========

@app.get("/api/v1/configs/{config_name}")
async def get_config(config_name: str):
    """获取特定配置"""
    if not service_state["initialized"]:
        raise HTTPException(
            status_code=status.HTTP_503_SERVICE_UNAVAILABLE,
            detail="AI引擎服务未初始化"
        )

    try:
        config_manager = app.state.config_manager
        config = config_manager.load_config(config_name)

        # 移除敏感信息（如API密钥）
        if "llm" in config:
            llm_config = config["llm"].copy()
            if "api_key" in llm_config:
                llm_config["api_key"] = "***HIDDEN***"
            config["llm"] = llm_config

        return {
            "config_name": config_name,
            "config": config,
            "timestamp": time.time()
        }

    except ValueError as e:
        raise HTTPException(
            status_code=status.HTTP_404_NOT_FOUND,
            detail=f"配置 {config_name} 未找到: {str(e)}"
        )
    except Exception as e:
        logger.error(f"获取配置失败: {e}")
        raise HTTPException(
            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
            detail=f"获取配置失败: {str(e)}"
        )


@app.post("/api/v1/configs/{config_name}")
async def update_config(config_name: str, config_data: Dict[str, Any]):
    """更新或创建配置"""
    if not service_state["initialized"]:
        raise HTTPException(
            status_code=status.HTTP_503_SERVICE_UNAVAILABLE,
            detail="AI引擎服务未初始化"
        )

    try:
        config_manager = app.state.config_manager

        # 验证配置
        errors = config_manager.validate_config(config_data)
        if errors:
            raise HTTPException(
                status_code=status.HTTP_400_BAD_REQUEST,
                detail=f"配置验证失败: {errors}"
            )

        # 保存配置
        config_path = config_manager.save_config(config_name, config_data)

        return {
            "config_name": config_name,
            "status": "saved",
            "path": config_path,
            "timestamp": time.time()
        }

    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"更新配置失败: {e}")
        raise HTTPException(
            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
            detail=f"更新配置失败: {str(e)}"
        )


# ========== Prometheus指标端点 ==========

@app.get("/metrics")
async def get_metrics():
    """Prometheus指标端点"""
    from prometheus_client import generate_latest, CONTENT_TYPE_LATEST
    from fastapi.responses import Response

    # 更新模块健康指标
    for module_name, initialized in service_state["modules"].items():
        health_value = 1 if initialized else 0
        MODULE_HEALTH.labels(module=module_name).set(health_value)

    return Response(
        content=generate_latest(),
        media_type=CONTENT_TYPE_LATEST
    )


if __name__ == "__main__":
    import uvicorn

    host = os.getenv("HOST", "0.0.0.0")
    port = int(os.getenv("PORT", "8081"))

    logger.info(f"启动AI引擎服务 (HackSynth集成版): http://{host}:{port}")
    logger.info(f"API文档: http://{host}:{port}/docs")
    logger.info(f"LLM代理端点: /api/v1/llm/*")
    logger.info(f"指标端点: http://{host}:{port}/metrics")

    uvicorn.run(
        "main:app",
        host=host,
        port=port,
        reload=os.getenv("ENVIRONMENT", "development") == "development"
    )