# 服务状态
service_state = {
    "initialized": False,
    "modules": {
        "decision_engine": False,
        "agent_controller": False,
        "llm_agent": False,
        "skill_registry": False,
        "llm_integrator": False,
        "config_manager": False
    }
}


@asynccontextmanager
async def lifespan(app: FastAPI):
    """应用生命周期管理"""
    logger.info("启动 ClawAI AI引擎服务 (集成HackSynth版本)...")

    try:
        # 检查模块可用性
        if not MODULES_AVAILABLE:
            logger.error("必要模块导入失败，服务无法启动")
            raise ImportError("无法导入必要模块")

        # 初始化AI引擎模块
        await initialize_ai_engine()
        service_state["initialized"] = True
        logger.info("AI引擎服务初始化完成")

        yield

    except Exception as e:
        logger.error(f"AI引擎服务启动失败: {e}")
        raise

    finally:
        # 关闭时
        logger.info("关闭 ClawAI AI引擎服务...")
        if "llm_integrator" in app.state.__dict__:
            app.state.llm_integrator.cleanup()
        service_state["initialized"] = False


async def initialize_ai_engine():
    """初始化AI引擎模块"""
    try:
        # 初始化决策引擎
        logger.info("初始化决策引擎...")
        decision_engine = DecisionEngine()
        app.state.decision_engine = decision_engine
        service_state["modules"]["decision_engine"] = True

        # 初始化技能注册表
        logger.info("初始化技能注册表...")
        skill_registry = SkillRegistry()
        app.state.skill_registry = skill_registry
        service_state["modules"]["skill_registry"] = True

        # 初始化推理引擎
        logger.info("初始化推理引擎...")
        reasoning_engine = PseudoReasoningEngine()
        app.state.reasoning_engine = reasoning_engine

        # 初始化Agent控制器池
        logger.info("初始化Agent控制器池...")
        app.state.agent_pool = {}
        service_state["modules"]["agent_controller"] = True

        # 初始化配置管理器
        logger.info("初始化LLM配置管理器...")
        config_manager = LLMConfigManager()
        app.state.config_manager = config_manager
        service_state["modules"]["config_manager"] = True

        # 初始化LLM代理集成器
        logger.info("初始化LLM代理集成器...")
        tool_executor_url = os.getenv("TOOL_EXECUTOR_URL", "http://tool-executor:8082")
        llm_integrator = LLMAgentIntegrator(
            config_manager=config_manager,
            tool_executor_url=tool_executor_url,
            skill_registry=skill_registry
        )
        app.state.llm_integrator = llm_integrator
        service_state["modules"]["llm_integrator"] = True
        service_state["modules"]["llm_agent"] = True

        # 创建默认配置（如果不存在）
        await ensure_default_configs(config_manager)

        logger.info("所有AI引擎模块初始化完成")

    except ImportError as e:
        logger.error(f"模块导入失败: {e}")
        raise
    except Exception as e:
        logger.error(f"AI引擎初始化失败: {e}")
        raise


async def ensure_default_configs(config_manager: 'LLMConfigManager'):
    """确保默认配置文件存在"""
    try:
        configs = config_manager.list_configs()

        if "clawai_pentest_agent" not in configs:
            logger.info("创建默认渗透测试代理配置...")

            # 从文件加载或创建默认配置
            config_path = os.path.join(os.path.dirname(__file__), "configs", "clawai_pentest_agent.json")
            if os.path.exists(config_path):
                import json
                with open(config_path, 'r', encoding='utf-8') as f:
                    default_config = json.load(f)
            else:
                # 创建默认配置
                default_config = config_manager.create_config_from_template(
                    "clawai_pentest_agent",
                    "pentest"
                )

            config_manager.save_config("clawai_pentest_agent", default_config)
            logger.info("默认配置创建完成")
        else:
            logger.info("默认配置已存在")

    except Exception as e:
        logger.error(f"确保默认配置失败: {e}")


