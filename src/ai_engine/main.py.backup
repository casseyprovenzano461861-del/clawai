# ========== 依赖函数 ==========

def get_llm_integrator():
    """获取LLM集成器依赖"""
    if not service_state["initialized"]:
        raise HTTPException(
            status_code=status.HTTP_503_SERVICE_UNAVAILABLE,
            detail="AI引擎服务未初始化"
        )
    return app.state.llm_integrator


def get_skill_registry():
    """获取技能注册表依赖"""
    if not service_state["initialized"]:
        raise HTTPException(
            status_code=status.HTTP_503_SERVICE_UNAVAILABLE,
            detail="AI引擎服务未初始化"
        )
    return app.state.skill_registry


def get_decision_engine():
    """获取决策引擎依赖"""
    if not service_state["initialized"]:
        raise HTTPException(
            status_code=status.HTTP_503_SERVICE_UNAVAILABLE,
            detail="AI引擎服务未初始化"
        )
    return app.state.decision_engine


# ========== 健康检查 ==========

@app.get("/health")
async def health_check():
    """AI引擎服务健康检查"""
    if not service_state["initialized"]:
        raise HTTPException(
            status_code=status.HTTP_503_SERVICE_UNAVAILABLE,
            detail="AI引擎服务未初始化"
        )

    modules_status = {}
    for module_name, initialized in service_state["modules"].items():
        modules_status[module_name] = "healthy" if initialized else "unhealthy"

    # 总体状态
    overall_status = "healthy"
    for initialized in service_state["modules"].values():
        if not initialized:
            overall_status = "degraded"

    # 检查LLM配置
    config_status = "unknown"
    if service_state["modules"]["config_manager"]:
        try:
            configs = app.state.config_manager.list_configs()
            config_status = f"available ({len(configs)} configs)"
        except Exception as e:
            config_status = f"error: {str(e)}"

    return {
        "service": "ai-engine-hacksynth",
        "status": overall_status,
        "version": "2.0.0",
        "timestamp": time.time(),
        "modules": modules_status,
        "llm_configs": config_status,
        "integrations": {
            "hacksynth": True,
            "planner_summarizer": True,
            "skill_integration": service_state["modules"]["skill_registry"]
        }
    }


