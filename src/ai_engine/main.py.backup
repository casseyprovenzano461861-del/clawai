@app.get("/api/v1/llm/configs")
async def list_llm_configs(llm_integrator: LLMAgentIntegrator = Depends(get_llm_integrator)):
    """列出可用的LLM代理配置"""
    try:
        configs = llm_integrator.list_available_configs()
        return {
            "configs": configs,
            "count": len(configs),
            "timestamp": time.time()
        }
    except Exception as e:
        logger.error(f"列出LLM配置失败: {e}")
        raise HTTPException(
            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
            detail=f"列出LLM配置失败: {str(e)}"
        )


@app.post("/api/v1/llm/analyze")
async def llm_analyze_target(
    request_data: Dict[str, Any],
    llm_integrator: LLMAgentIntegrator = Depends(get_llm_integrator)
):
    """使用LLM代理分析目标"""
    try:
        target = request_data.get("target", "")
        config_name = request_data.get("config_name", "clawai_pentest_agent")

        if not target:
            raise HTTPException(
                status_code=status.HTTP_400_BAD_REQUEST,
                detail="必须提供目标地址"
            )

        analysis_result = await llm_integrator.analyze_target(target, config_name)

        logger.info(f"LLM目标分析完成: {target}")
        return analysis_result

    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"LLM目标分析失败: {e}")
        raise HTTPException(
            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
            detail=f"LLM目标分析失败: {str(e)}"
        )


@app.post("/api/v1/llm/generate-plan")
async def llm_generate_attack_plan(
