# -*- coding: utf-8 -*-
"""
综合监控系统
提供系统性能监控、指标收集和告警功能
"""

import time
import psutil
import threading
import json
from typing import Dict, Any, List, Optional, Callable
from dataclasses import dataclass, field
from datetime import datetime, timedelta
from enum import Enum
import logging
import asyncio

logger = logging.getLogger(__name__)


class AlertLevel(str, Enum):
    """告警级别"""
    INFO = "info"        # 信息
    WARNING = "warning"  # 警告
    ERROR = "error"      # 错误
    CRITICAL = "critical" # 严重


class MetricType(str, Enum):
    """指标类型"""
    SYSTEM = "system"      # 系统指标
    APPLICATION = "app"    # 应用指标
    BUSINESS = "business"  # 业务指标
    CUSTOM = "custom"      # 自定义指标


@dataclass
class Alert:
    """告警信息"""
    id: str
    level: AlertLevel
    title: str
    message: str
    source: str
    timestamp: datetime
    acknowledged: bool = False
    acknowledged_by: Optional[str] = None
    acknowledged_at: Optional[datetime] = None
    metadata: Dict[str, Any] = field(default_factory=dict)
    
    def to_dict(self) -> Dict[str, Any]:
        """转换为字典"""
        return {
            "id": self.id,
            "level": self.level.value,
            "title": self.title,
            "message": self.message,
            "source": self.source,
            "timestamp": self.timestamp.isoformat(),
            "acknowledged": self.acknowledged,
            "acknowledged_by": self.acknowledged_by,
            "acknowledged_at": self.acknowledged_at.isoformat() if self.acknowledged_at else None,
            "metadata": self.metadata
        }


@dataclass
class SystemMetrics:
    """系统指标"""
    timestamp: datetime
    cpu_percent: float
    memory_percent: float
    memory_used_mb: float
    memory_total_mb: float
    disk_percent: float
    disk_used_gb: float
    disk_total_gb: float
    network_sent_mb: float
    network_recv_mb: float
    process_count: int
    thread_count: int
    open_files: int
    connections: int
    
    def to_dict(self) -> Dict[str, Any]:
        """转换为字典"""
        return {
            "timestamp": self.timestamp.isoformat(),
            "cpu_percent": round(self.cpu_percent, 2),
            "memory_percent": round(self.memory_percent, 2),
            "memory_used_mb": round(self.memory_used_mb, 2),
            "memory_total_mb": round(self.memory_total_mb, 2),
            "disk_percent": round(self.disk_percent, 2),
            "disk_used_gb": round(self.disk_used_gb, 2),
            "disk_total_gb": round(self.disk_total_gb, 2),
            "network_sent_mb": round(self.network_sent_mb, 2),
            "network_recv_mb": round(self.network_recv_mb, 2),
            "process_count": self.process_count,
            "thread_count": self.thread_count,
            "open_files": self.open_files,
            "connections": self.connections
        }


class AlertManager:
    """告警管理器"""
    
    def __init__(self):
        self.alerts: Dict[str, Alert] = {}
        self.alert_handlers: List[Callable[[Alert], None]] = []
        self.alert_rules: List[Dict[str, Any]] = []
        
        # 默认告警规则
        self._setup_default_rules()
        
        logger.info("AlertManager 初始化完成")
    
    def _setup_default_rules(self):
        """设置默认告警规则"""
        self.alert_rules = [
            {
                "name": "high_cpu_usage",
                "condition": lambda metrics: metrics.cpu_percent > 80,
                "level": AlertLevel.WARNING,
                "title": "CPU使用率过高",
                "message": "CPU使用率超过80%",
                "source": "system"
            },
            {
                "name": "high_memory_usage",
                "condition": lambda metrics: metrics.memory_percent > 85,
                "level": AlertLevel.WARNING,
                "title": "内存使用率过高",
                "message": "内存使用率超过85%",
                "source": "system"
            },
            {
                "name": "critical_memory_usage",
                "condition": lambda metrics: metrics.memory_percent > 95,
                "level": AlertLevel.CRITICAL,
                "title": "内存使用率严重过高",
                "message": "内存使用率超过95%，系统可能不稳定",
                "source": "system"
            },
            {
                "name": "high_disk_usage",
                "condition": lambda metrics: metrics.disk_percent > 90,
                "level": AlertLevel.WARNING,
                "title": "磁盘使用率过高",
                "message": "磁盘使用率超过90%",
                "source": "system"
            },
            {
                "name": "low_disk_space",
                "condition": lambda metrics: metrics.disk_total_gb - metrics.disk_used_gb < 5,
                "level": AlertLevel.CRITICAL,
                "title": "磁盘空间不足",
                "message": "磁盘剩余空间小于5GB",
                "source": "system"
            }
        ]
    
    def add_alert_handler(self, handler: Callable[[Alert], None]):
        """添加告警处理器"""
        self.alert_handlers.append(handler)
    
    def create_alert(self, level: AlertLevel, title: str, message: str, source: str, metadata: Dict[str, Any] = None) -> Alert:
        """创建告警"""
        alert_id = f"alert_{int(time.time())}_{len(self.alerts)}"
        
        alert = Alert(
            id=alert_id,
            level=level,
            title=title,
            message=message,
            source=source,
            timestamp=datetime.now(),
            metadata=metadata or {}
        )
        
        self.alerts[alert_id] = alert
        
        # 触发告警处理器
        for handler in self.alert_handlers:
            try:
                handler(alert)
            except Exception as e:
                logger.error(f"告警处理器执行失败: {e}")
        
        logger.info(f"告警已创建 - {level}: {title}")
        
        return alert
    
    def check_metrics(self, metrics: SystemMetrics) -> List[Alert]:
        """检查指标并生成告警"""
        new_alerts = []
        
        for rule in self.alert_rules:
            try:
                if rule["condition"](metrics):
                    # 检查是否已存在相同告警
                    existing_alert = self._find_existing_alert(rule["name"], metrics.timestamp)
                    
                    if not existing_alert:
                        alert = self.create_alert(
                            level=rule["level"],
                            title=rule["title"],
                            message=rule["message"],
                            source=rule["source"],
                            metadata={
                                "rule_name": rule["name"],
                                "metrics": metrics.to_dict()
                            }
                        )
                        new_alerts.append(alert)
                        
            except Exception as e:
                logger.error(f"告警规则检查失败 {rule.get('name', 'unknown')}: {e}")
        
        return new_alerts
    
    def _find_existing_alert(self, rule_name: str, timestamp: datetime) -> Optional[Alert]:
        """查找已存在的告警"""
        for alert in self.alerts.values():
            if (alert.metadata.get("rule_name") == rule_name and 
                not alert.acknowledged and
                (timestamp - alert.timestamp) < timedelta(minutes=5)):
                return alert
        return None
    
    def acknowledge_alert(self, alert_id: str, user: str = "system") -> bool:
        """确认告警"""
        if alert_id in self.alerts:
            alert = self.alerts[alert_id]
            alert.acknowledged = True
            alert.acknowledged_by = user
            alert.acknowledged_at = datetime.now()
            logger.info(f"告警已确认 - ID: {alert_id}, 用户: {user}")
            return True
        return False
    
    def get_alerts(
        self, 
        level: Optional[AlertLevel] = None,
        acknowledged: Optional[bool] = None,
        source: Optional[str] = None,
        limit: int = 100
    ) -> List[Alert]:
        """获取告警列表"""
        alerts = list(self.alerts.values())
        
        # 过滤
        if level:
            alerts = [a for a in alerts if a.level == level]
        
        if acknowledged is not None:
            alerts = [a for a in alerts if a.acknowledged == acknowledged]
        
        if source:
            alerts = [a for a in alerts if a.source == source]
        
        # 按时间排序（最新的在前）
        alerts.sort(key=lambda a: a.timestamp, reverse=True)
        
        return alerts[:limit]
    
    def cleanup_old_alerts(self, max_age_days: int = 7):
        """清理旧告警"""
        cutoff_time = datetime.now() - timedelta(days=max_age_days)
        
        alerts_to_remove = []
        for alert_id, alert in self.alerts.items():
            if alert.timestamp < cutoff_time:
                alerts_to_remove.append(alert_id)
        
        for alert_id in alerts_to_remove:
            del self.alerts[alert_id]
        
        logger.info(f"清理了 {len(alerts_to_remove)} 个旧告警")
        return len(alerts_to_remove)


class ComprehensiveMonitor:
    """
    综合监控系统
    
    特性：
    1. 系统性能监控（CPU、内存、磁盘、网络）
    2. 应用指标监控
    3. 业务指标监控
    4. 实时告警系统
    5. 历史数据存储
    6. 性能趋势分析
    """
    
    def __init__(self, collection_interval: int = 30, history_size: int = 1000):
        """
        初始化监控系统
        
        Args:
            collection_interval: 指标收集间隔（秒）
            history_size: 历史数据保留数量
        """
        self.collection_interval = collection_interval
        self.history_size = history_size
        
        # 指标存储
        self.system_metrics_history: List[SystemMetrics] = []
        self.application_metrics: Dict[str, Any] = {}
        self.business_metrics: Dict[str, Any] = {}
        self.custom_metrics: Dict[str, Any] = {}
        
        # 告警管理器
        self.alert_manager = AlertManager()
        
        # 监控线程
        self.monitoring_thread = None
        self.running = False
        
        # 网络流量基准
        self.last_network_stats = None
        self.last_network_time = None
        
        logger.info(f"ComprehensiveMonitor 初始化完成 - 收集间隔: {collection_interval}s")
    
    def start(self):
        """启动监控"""
        if self.running:
            logger.warning("监控系统已经在运行")
            return
        
        self.running = True
        self.monitoring_thread = threading.Thread(target=self._monitoring_loop, daemon=True)
        self.monitoring_thread.start()
        
        logger.info("监控系统已启动")
    
    def stop(self):
        """停止监控"""
        if not self.running:
            logger.warning("监控系统未运行")
            return
        
        self.running = False
        if self.monitoring_thread:
            self.monitoring_thread.join(timeout=5)
        
        logger.info("监控系统已停止")
    
    def _monitoring_loop(self):
        """监控循环"""
        logger.info("监控循环已启动")
        
        while self.running:
            try:
                # 收集系统指标
                metrics = self._collect_system_metrics()
                self.system_metrics_history.append(metrics)
                
                # 限制历史数据大小
                if len(self.system_metrics_history) > self.history_size:
                    self.system_metrics_history = self.system_metrics_history[-self.history_size:]
                
                # 检查告警
                self.alert_manager.check_metrics(metrics)
                
                # 收集应用指标
                self._collect_application_metrics()
                
                # 收集业务指标
                self._collect_business_metrics()
                
                # 等待下一次收集
                time.sleep(self.collection_interval)
                
            except Exception as e:
                logger.error(f"监控收集失败: {e}")
                time.sleep(5)  # 错误后等待5秒
    
    def _collect_system_metrics(self) -> SystemMetrics:
        """收集系统指标"""
        # CPU使用率
        cpu_percent = psutil.cpu_percent(interval=0.1)
        
        # 内存使用情况
        memory = psutil.virtual_memory()
        memory_percent = memory.percent
        memory_used_mb = memory.used / (1024 * 1024)
        memory_total_mb = memory.total / (1024 * 1024)
        
        # 磁盘使用情况
        disk = psutil.disk_usage('/')
        disk_percent = disk.percent
        disk_used_gb = disk.used / (1024 * 1024 * 1024)
        disk_total_gb = disk.total / (1024 * 1024 * 1024)
        
        # 网络流量
        network = psutil.net_io_counters()
        current_time = time.time()
        
        network_sent_mb = network.bytes_sent / (1024 * 1024)
        network_recv_mb = network.bytes_recv / (1024 * 1024)
        
        # 计算网络速率
        if self.last_network_stats and self.last_network_time:
            time_diff = current_time - self.last_network_time
            if time_diff > 0:
                sent_diff = network.bytes_sent - self.last_network_stats.bytes_sent
                recv_diff = network.bytes_recv - self.last_network_stats.bytes_recv
                
                # 存储速率（MB/s）
                self.application_metrics["network_sent_rate"] = (sent_diff / time_diff) / (1024 * 1024)
                self.application_metrics["network_recv_rate"] = (recv_diff / time_diff) / (1024 * 1024)
        
        self.last_network_stats = network
        self.last_network_time = current_time
        
        # 进程和线程数
        process_count = len(psutil.pids())
        
        # 线程数（估算）
        thread_count = 0
        for proc in psutil.process_iter(['pid', 'num_threads']):
            try:
                thread_count += proc.info['num_threads'] or 0
            except (psutil.NoSuchProcess, psutil.AccessDenied):
                pass
        
        # 打开文件数
        open_files = 0
        try:
            for proc in psutil.process_iter(['pid', 'open_files']):
                try:
                    if proc.info['open_files']:
                        open_files += len(proc.info['open_files'])
                except (psutil.NoSuchProcess, psutil.AccessDenied, TypeError):
                    pass
        except Exception:
            open_files = 0
        
        # 网络连接数
        connections = 0
        try:
            connections = len(psutil.net_connections())
        except Exception:
            connections = 0
        
        return SystemMetrics(
            timestamp=datetime.now(),
            cpu_percent=cpu_percent,
            memory_percent=memory_percent,
            memory_used_mb=memory_used_mb,
            memory_total_mb=memory_total_mb,
            disk_percent=disk_percent,
            disk_used_gb=disk_used_gb,
            disk_total_gb=disk_total_gb,
            network_sent_mb=network_sent_mb,
            network_recv_mb=network_recv_mb,
            process_count=process_count,
            thread_count=thread_count,
            open_files=open_files,
            connections=connections
        )
    
    def _collect_application_metrics(self):
        """收集应用指标"""
        try:
            # 获取当前进程信息
            current_process = psutil.Process()
            
            self.application_metrics.update({
                "process_cpu_percent": current_process.cpu_percent(),
                "process_memory_percent": current_process.memory_percent(),
                "process_memory_mb": current_process.memory_info().rss / (1024 * 1024),
                "process_threads": current_process.num_threads(),
                "process_open_files": len(current_process.open_files()) if hasattr(current_process, 'open_files') else 0,
                "process_create_time": datetime.fromtimestamp(current_process.create_time()).isoformat(),
                "process_status": current_process.status()
            })
            
        except Exception as e:
            logger.error(f"收集应用指标失败: {e}")
    
    def _collect_business_metrics(self):
        """收集业务指标"""
        # 这里可以添加业务特定的指标收集逻辑
        # 例如：API请求数、任务执行数、缓存命中率等
        
        # 示例：获取当前时间戳
        self.business_metrics["last_collection_time"] = datetime.now().isoformat()
    
    def record_custom_metric(self, name: str, value: Any, metric_type: MetricType = MetricType.CUSTOM):
        """记录自定义指标"""
        if metric_type not in self.custom_metrics:
            self.custom_metrics[metric_type] = {}
        
        self.custom_metrics[metric_type][name] = {
            "value": value,
            "timestamp": datetime.now().isoformat(),
            "type": metric_type.value
        }
    
    def get_current_metrics(self) -> Dict[str, Any]:
        """获取当前所有指标"""
        if not self.system_metrics_history:
            return {"error": "No metrics available"}
        
        latest_metrics = self.system_metrics_history[-1]
        
        return {
            "system": latest_metrics
    def to_dict(self) -> Dict[str, Any]:
        """转换为字典"""
        return {
            "id": self.id,
            "level": self.level.value,
            "title": self.title,
            "message": self.message,
            "source": self.source,
            "timestamp": self.timestamp.isoformat(),
            "acknowledged": self.acknowledged,
            "acknowledged_by": self.acknowledged_by,
            "acknowledged_at": self.acknowledged_at.isoformat() if self.acknowledged_at else None,
            "metadata": self.metadata
        }

import time
import json




from typing import Dict, Any, Optional, Callable, Union

class AlertManager:
    """告警管理器"""
    
    def __init__(self):
        self.alerts: Dict[str, Alert] = {}
        self.alert_handlers: List[Callable[[Alert], None]] = []
        self.alert_rules: List[Dict[str, Any]] = []
        
        # 默认告警规则
        self._setup_default_rules()
        
        logger.info("AlertManager 初始化完成")
    
    def _setup_default_rules(self):
        """设置默认告警规则"""
        self.alert_rules = [
            {
                "name": "high_cpu_usage",
                "condition": lambda metrics: metrics.cpu_percent > 80,
                "level": AlertLevel.WARNING,
                "title": "CPU使用率过高",
                "message": "CPU使用率超过80%",
                "source": "system"
            },
            {
                "name": "high_memory_usage",
                "condition": lambda metrics: metrics.memory_percent > 85,
                "level": AlertLevel.WARNING,
                "title": "内存使用率过高",
                "message": "内存使用率超过85%",
                "source": "system"
            },
            {
                "name": "critical_memory_usage",
                "condition": lambda metrics: metrics.memory_percent > 95,
                "level": AlertLevel.CRITICAL,
                "title": "内存使用率严重过高",
                "message": "内存使用率超过95%，系统可能不稳定",
                "source": "system"
            },
            {
                "name": "high_disk_usage",
                "condition": lambda metrics: metrics.disk_percent > 90,
                "level": AlertLevel.WARNING,
                "title": "磁盘使用率过高",
                "message": "磁盘使用率超过90%",
                "source": "system"
            },
            {
                "name": "low_disk_space",
                "condition": lambda metrics: metrics.disk_total_gb - metrics.disk_used_gb < 5,
                "level": AlertLevel.CRITICAL,
                "title": "磁盘空间不足",
                "message": "磁盘剩余空间小于5GB",
                "source": "system"
            }
        ]
    
    def add_alert_handler(self, handler: Callable[[Alert], None]):
        """添加告警处理器"""
        self.alert_handlers.append(handler)
    
    def create_alert(self, level: AlertLevel, title: str, message: str, source: str, metadata: Dict[str, Any] = None) -> Alert:
        """创建告警"""
        alert_id = f"alert_{int(time.time())}_{len(self.alerts)}"
        
        alert = Alert(
            id=alert_id,
            level=level,
            title=title,
            message=message,
            source=source,
            timestamp=datetime.now(),
            metadata=metadata or {}
        )
        
        self.alerts[alert_id] = alert
        
        # 触发告警处理器
        for handler in self.alert_handlers:
            try:
                handler(alert)
            except Exception as e:
                logger.error(f"告警处理器执行失败: {e}")
        
        logger.info(f"告警已创建 - {level}: {title}")
        
        return alert
    
    def check_metrics(self, metrics: SystemMetrics) -> List[Alert]:
        """检查指标并生成告警"""
        new_alerts = []
        
        for rule in self.alert_rules:
            try:
                if rule["condition"](metrics):
                    # 检查是否已存在相同告警
                    existing_alert = self._find_existing_alert(rule["name"], metrics.timestamp)
                    
                    if not existing_alert:
                        alert = self.create_alert(
                            level=rule["level"],
                            title=rule["title"],
                            message=rule["message"],
                            source=rule["source"],
                            metadata={
                                "rule_name": rule["name"],
                                "metrics": metrics.to_dict()
                            }
                        )
                        new_alerts.append(alert)
                        
            except Exception as e:
                logger.error(f"告警规则检查失败 {rule.get('name', 'unknown')}: {e}")
        
        return new_alerts
    
    def _find_existing_alert(self, rule_name: str, timestamp: datetime) -> Optional[Alert]:
        """查找已存在的告警"""
        for alert in self.alerts.values():
            if (alert.metadata.get("rule_name") == rule_name and 
                not alert.acknowledged and
                (timestamp - alert.timestamp) < timedelta(minutes=5)):
                return alert
        return None
    
    def acknowledge_alert(self, alert_id: str, user: str = "system") -> bool:
        """确认告警"""
        if alert_id in self.alerts:
            alert = self.alerts[alert_id]
            alert.acknowledged = True
            alert.acknowledged_by = user
            alert.acknowledged_at = datetime.now()
            logger.info(f"告警已确认 - ID: {alert_id}, 用户: {user}")
            return True
        return False
    
    def get_alerts(
        self, 
        level: Optional[AlertLevel] = None,
        acknowledged: Optional[bool] = None,
        source: Optional[str] = None,
        limit: int = 100
    ) -> List[Alert]:
        """获取告警列表"""
        alerts = list(self.alerts.values())
        
        # 过滤
        if level:
            alerts = [a for a in alerts if a.level == level]
        
        if acknowledged is not None:
            alerts = [a for a in alerts if a.acknowledged == acknowledged]
        
        if source:
            alerts = [a for a in alerts if a.source == source]
        
        # 按时间排序（最新的在前）
        alerts.sort(key=lambda a: a.timestamp, reverse=True)
        
        return alerts[:limit]
    
    def cleanup_old_alerts(self, max_age_days: int = 7):
        """清理旧告警"""
        cutoff_time = datetime.now() - timedelta(days=max_age_days)
        
        alerts_to_remove = []
        for alert_id, alert in self.alerts.items():
            if alert.timestamp < cutoff_time:
                alerts_to_remove.append(alert_id)
        
        for alert_id in alerts_to_remove:
            del self.alerts[alert_id]
        
        logger.info(f"清理了 {len(alerts_to_remove)} 个旧告警")
        return len(alerts_to_remove)
import logging
from datetime import datetime, timedelta








class ComprehensiveMonitor:
    """
    综合监控系统
    misses: int = 0

    特性：
    1. 系统性能监控（CPU、内存、磁盘、网络）
    2. 应用指标监控
    3. 业务指标监控
    4. 实时告警系统
    5. 历史数据存储
    6. 性能趋势分析
    """
    
    def __init__(self, collection_interval: int = 30, history_size: int = 1000):
        """
        初始化监控系统
        
        Args:
            collection_interval: 指标收集间隔（秒）
            history_size: 历史数据保留数量
        """
        self.collection_interval = collection_interval
        self.history_size = history_size
        
        # 指标存储
        self.system_metrics_history: List[SystemMetrics] = []
        self.application_metrics: Dict[str, Any] = {}
        self.business_metrics: Dict[str, Any] = {}
        self.custom_metrics: Dict[str, Any] = {}
        
        # 告警管理器
        self.alert_manager = AlertManager()
        
        # 监控线程
        self.monitoring_thread = None
        self.running = False
        
        # 网络流量基准
        self.last_network_stats = None
        self.last_network_time = None
        
        logger.info(f"ComprehensiveMonitor 初始化完成 - 收集间隔: {collection_interval}s")
    
    def start(self):
        """启动监控"""
        if self.running:
            logger.warning("监控系统已经在运行")
            return
        
        self.running = True
        self.monitoring_thread = threading.Thread(target=self._monitoring_loop, daemon=True)
        self.monitoring_thread.start()
        
        logger.info("监控系统已启动")
    
    def stop(self):
        """停止监控"""
        if not self.running:
            logger.warning("监控系统未运行")
            return
        
        self.running = False
        if self.monitoring_thread:
            self.monitoring_thread.join(timeout=5)
        
        logger.info("监控系统已停止")
    
    def _monitoring_loop(self):
        """监控循环"""
        logger.info("监控循环已启动")
        
        while self.running:
            try:
                # 收集系统指标
                metrics = self._collect_system_metrics()
                self.system_metrics_history.append(metrics)
                
                # 限制历史数据大小
                if len(self.system_metrics_history) > self.history_size:
                    self.system_metrics_history = self.system_metrics_history[-self.history_size:]
                
                # 检查告警
                self.alert_manager.check_metrics(metrics)
                
                # 收集应用指标
                self._collect_application_metrics()
                
                # 收集业务指标
                self._collect_business_metrics()
                
                # 等待下一次收集
                time.sleep(self.collection_interval)
                
            except Exception as e:
                logger.error(f"监控收集失败: {e}")
                time.sleep(5)  # 错误后等待5秒
    
    def _collect_system_metrics(self) -> SystemMetrics:
        """收集系统指标"""
        # CPU使用率
        cpu_percent = psutil.cpu_percent(interval=0.1)
        
        # 内存使用情况
        memory = psutil.virtual_memory()
        memory_percent = memory.percent
        memory_used_mb = memory.used / (1024 * 1024)
        memory_total_mb = memory.total / (1024 * 1024)
        
        # 磁盘使用情况
        disk = psutil.disk_usage('/')
        disk_percent = disk.percent
        disk_used_gb = disk.used / (1024 * 1024 * 1024)
        disk_total_gb = disk.total / (1024 * 1024 * 1024)
        
        # 网络流量
        network = psutil.net_io_counters()
        current_time = time.time()
        
        network_sent_mb = network.bytes_sent / (1024 * 1024)
        network_recv_mb = network.bytes_recv / (1024 * 1024)
        
        # 计算网络速率
        if self.last_network_stats and self.last_network_time:
            time_diff = current_time - self.last_network_time
            if time_diff > 0:
                sent_diff = network.bytes_sent - self.last_network_stats.bytes_sent
                recv_diff = network.bytes_recv - self.last_network_stats.bytes_recv
                
                # 存储速率（MB/s）
                self.application_metrics["network_sent_rate"] = (sent_diff / time_diff) / (1024 * 1024)
                self.application_metrics["network_recv_rate"] = (recv_diff / time_diff) / (1024 * 1024)
        
        self.last_network_stats = network
        self.last_network_time = current_time
        
        # 进程和线程数
        process_count = len(psutil.pids())
        
        # 线程数（估算）
        thread_count = 0
        for proc in psutil.process_iter(['pid', 'num_threads']):
            try:
                thread_count += proc.info['num_threads'] or 0
            except (psutil.NoSuchProcess, psutil.AccessDenied):
                pass
        
        # 打开文件数
        open_files = 0
        try:
            for proc in psutil.process_iter(['pid', 'open_files']):
                try:
                    if proc.info['open_files']:
                        open_files += len(proc.info['open_files'])
                except (psutil.NoSuchProcess, psutil.AccessDenied, TypeError):
                    pass
        except Exception:
            open_files = 0
        
        # 网络连接数
        connections = 0
        try:
            connections = len(psutil.net_connections())
        except Exception:
            connections = 0
        
        return SystemMetrics(
            timestamp=datetime.now(),
            cpu_percent=cpu_percent,
            memory_percent=memory_percent,
            memory_used_mb=memory_used_mb,
            memory_total_mb=memory_total_mb,
            disk_percent=disk_percent,
            disk_used_gb=disk_used_gb,
            disk_total_gb=disk_total_gb,
            network_sent_mb=network_sent_mb,
            network_recv_mb=network_recv_mb,
            process_count=process_count,
            thread_count=thread_count,
            open_files=open_files,
            connections=connections
        )
    
    def _collect_application_metrics(self):
        """收集应用指标"""
        try:
            # 获取当前进程信息
            current_process = psutil.Process()
            
            self.application_metrics.update({
                "process_cpu_percent": current_process.cpu_percent(),
                "process_memory_percent": current_process.memory_percent(),
                "process_memory_mb": current_process.memory_info().rss / (1024 * 1024),
                "process_threads": current_process.num_threads(),
                "process_open_files": len(current_process.open_files()) if hasattr(current_process, 'open_files') else 0,
                "process_create_time": datetime.fromtimestamp(current_process.create_time()).isoformat(),
                "process_status": current_process.status()
            })
            
        except Exception as e:
            logger.error(f"收集应用指标失败: {e}")
    
    def _collect_business_metrics(self):
        """收集业务指标"""
        # 这里可以添加业务特定的指标收集逻辑
        # 例如：API请求数、任务执行数、缓存命中率等
        
        # 示例：获取当前时间戳
        self.business_metrics["last_collection_time"] = datetime.now().isoformat()
    
    def record_custom_metric(self, name: str, value: Any, metric_type: MetricType = MetricType.CUSTOM):
        """记录自定义指标"""
        if metric_type not in self.custom_metrics:
            self.custom_metrics[metric_type] = {}
        
        self.custom_metrics[metric_type][name] = {
            "value": value,
            "timestamp": datetime.now().isoformat(),
            "type": metric_type.value
        }
    
    def get_current_metrics(self) -> Dict[str, Any]:
        """获取当前所有指标"""
        if not self.system_metrics_history:
            return {"error": "No metrics available"}
        
        latest_metrics = self.system_metrics_history[-1]
        
        return {
            "system": latest_metrics
    evictions: int = 0
    errors: int = 0
    
    def record_hit(self):
