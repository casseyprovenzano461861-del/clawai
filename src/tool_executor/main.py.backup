        def __init__(self, *args, **kwargs):
            pass
    class Histogram:
        def __init__(self, *args, **kwargs):
            pass
    class Gauge:
        def __init__(self, *args, **kwargs):
            pass
    def generate_latest():
        return b''
    CONTENT_TYPE_LATEST = 'text/plain'
import docker
import redis
import asyncio

# 从共享模块导入指标管理器
import sys
sys.path.append('../../shared/backend')
from monitoring.metrics import get_metrics_manager, counter, gauge, histogram
from security.sandbox import get_sandbox_config, SandboxSecurityLevel

# 本地导入
from tool_loader import get_tool_loader, ToolLoader

# 配置日志
logging.basicConfig(
    level=os.getenv("LOG_LEVEL", "INFO"),
    format='%(asctime)s - %(name)s - %(levelname)s - %(message)s'
)
logger = logging.getLogger(__name__)

# 全局变量
docker_client = None
redis_client = None
task_queue = None

# Prometheus指标定义 - 使用统一的指标管理器
TOOL_EXECUTIONS = counter(
    'tool_executor_executions_total',
    '工具执行总次数',
    labelnames=['tool_name', 'status']
)

TASK_QUEUE_SIZE = gauge(
    'tool_executor_task_queue_size',
    '任务队列大小'
)

