    'tool_executor_service_health',
    '服务健康状态',
    labelnames=['service']
)

logger.info("工具执行器指标初始化完成")


@asynccontextmanager
async def lifespan(app: FastAPI):
    """应用生命周期管理"""
    logger.info("启动 ClawAI 工具执行服务...")

    global docker_client, redis_client, task_queue

    try:
        # 初始化Docker客户端 - Windows环境优化版本
        docker_host = os.getenv("DOCKER_HOST")
        logger.info(f"环境变量DOCKER_HOST={docker_host}")

        # 重新导入docker模块，避免作用域问题
        import docker
        logger.info(f"docker模块版本: {docker.__version__}")

        # 检测当前环境
        import platform
        is_windows = platform.system().lower() == "windows"
        logger.info(f"检测到系统平台: {platform.system()}, is_windows={is_windows}")

        # 根据平台优化连接顺序
        connection_methods = []

        # 首先尝试环境变量指定的连接方式
        if docker_host:
            connection_methods.append(docker_host)

        # 根据平台添加优化的连接方式
        if is_windows:
            # Windows环境：优先尝试命名管道，然后尝试Unix套接字（WSL2）
            connection_methods.extend([
                "npipe:////./pipe/docker_engine",  # Windows named pipe (Windows容器)
                "unix:///var/run/docker.sock",     # Unix socket (WSL2 Linux容器)
                "tcp://localhost:2375",            # TCP connection
                "tcp://host.docker.internal:2375", # Docker Desktop特殊主机名
            ])
        else:
            # Linux/Unix环境：优先尝试Unix套接字
            connection_methods.extend([
                "unix:///var/run/docker.sock",     # Unix socket
                "tcp://localhost:2375",            # TCP connection
                "tcp://host.docker.internal:2375", # Docker Desktop特殊主机名
                "npipe:////./pipe/docker_engine",  # Windows named pipe
            ])

        # 尝试多种Docker连接方法
        # docker_client 已在全局作用域中声明
        last_error = None

        # 方法1: 首先尝试docker.from_env()，它会自动处理大部分情况
        try:
            logger.info("尝试使用docker.from_env()自动检测Docker连接")
            docker_client = docker.from_env(timeout=10)
            version_info = docker_client.version()
            logger.info(f"Docker连接成功 (自动检测)")
            logger.info(f"Docker版本: {version_info.get('Version', 'unknown')}")
            logger.info(f"Docker API版本: {version_info.get('ApiVersion', 'unknown')}")
        except Exception as e:
            logger.warning(f"docker.from_env()失败: {e}")
            docker_client = None

        # 方法2: 如果自动检测失败，尝试手动连接
        if not docker_client:
            # 扩展连接方法，包含不同的URL格式
            extended_methods = []

            # 添加所有基本方法
            extended_methods.extend(connection_methods)

            # 添加替代的Unix套接字格式
            extended_methods.extend([
                "/var/run/docker.sock",  # 直接路径，不带unix://前缀
                "unix://var/run/docker.sock",  # 不带前导斜杠
            ])

            # 添加TCP备用端口
            extended_methods.extend([
                "tcp://127.0.0.1:2375",
                "tcp://0.0.0.0:2375",
            ])

            # 尝试所有方法
            for method in extended_methods:
                try:
                    logger.info(f"尝试连接Docker: {method}")

                    # 特殊处理：检查Unix套接字文件是否存在
                    socket_path = None
                    if method.startswith("unix://"):
                        socket_path = method.replace("unix://", "")
                    elif method == "/var/run/docker.sock":
                        socket_path = method
                    elif "://" not in method and method.startswith("/"):
                        socket_path = method

                    if socket_path and not os.path.exists(socket_path):
                        logger.warning(f"Unix套接字文件不存在: {socket_path}")
                        continue

                    # 尝试不同的客户端配置
                    if method.startswith("unix://") or (method.startswith("/") and "://" not in method):
                        # Unix套接字连接
                        if method.startswith("unix://"):
                            base_url = method
                        else:
                            base_url = f"unix://{method}"

                        # 尝试不同的配置
                        configs_to_try = [
                            {"base_url": base_url, "timeout": 10},
                            {"base_url": base_url, "timeout": 10, "use_ssh_client": False},
                            {"base_url": base_url, "timeout": 10, "max_pool_size": 1},
                        ]

                        for config in configs_to_try:
                            try:
                                docker_client = docker.DockerClient(**config)
                                version_info = docker_client.version()
                                logger.info(f"Docker连接成功: {method} (配置: {config})")
                                logger.info(f"Docker版本: {version_info.get('Version', 'unknown')}")
                                logger.info(f"Docker API版本: {version_info.get('ApiVersion', 'unknown')}")
                                os.environ["DOCKER_HOST"] = base_url
                                break
                            except Exception as inner_e:
                                logger.debug(f"配置 {config} 失败: {inner_e}")
                                if docker_client:
                                    docker_client.close()
                                docker_client = None
                                continue

                        if docker_client:
                            break
                    else:
                        # TCP或npipe连接
                        docker_client = docker.DockerClient(base_url=method, timeout=10)
                        version_info = docker_client.version()
                        logger.info(f"Docker连接成功: {method}")
                        logger.info(f"Docker版本: {version_info.get('Version', 'unknown')}")
                        logger.info(f"Docker API版本: {version_info.get('ApiVersion', 'unknown')}")
                        os.environ["DOCKER_HOST"] = method
                        break

                except Exception as e:
                    last_error = e
                    logger.warning(f"Docker连接失败 {method}: {e}")
                    if docker_client:
                        docker_client.close()
                    docker_client = None
                    continue

        # 方法3: 尝试使用低级别APIClient作为最后手段
        if not docker_client:
            try:
                logger.info("尝试使用低级别docker.APIClient")
                import docker.api
                # 尝试直接使用APIClient
                api_client = docker.APIClient(base_url='unix:///var/run/docker.sock', timeout=10)
                version_info = api_client.version()
                logger.info(f"APIClient连接成功")
                logger.info(f"Docker版本: {version_info.get('Version', 'unknown')}")
                # 从APIClient创建DockerClient
                docker_client = docker.DockerClient.from_env()
                logger.info("从APIClient成功创建DockerClient")
            except Exception as e:
                logger.warning(f"APIClient也失败: {e}")
                if 'api_client' in locals():
                    api_client.close()

        if not docker_client:
            error_msg = f"所有Docker连接方式都失败，最后错误: {last_error}"
            logger.warning(error_msg)
            logger.warning("Docker客户端初始化失败，工具执行功能将不可用")
            # 不抛出异常，继续启动服务
            docker_client = None
        else:
            # 设置服务健康指标
            SERVICE_HEALTH.labels(service="docker").set(1)

        # 初始化Redis客户端
        redis_host = os.getenv("REDIS_HOST", "redis")
        redis_port = int(os.getenv("REDIS_PORT", "6379"))
        redis_client = redis.Redis(
            host=redis_host,
            port=redis_port,
            decode_responses=True
        )
        # 测试Redis连接
        redis_client.ping()
        logger.info("Redis客户端初始化完成")

        # 初始化工具加载器（不依赖于Docker客户端）
        try:
            tool_loader = get_tool_loader()
            app.state.tool_loader = tool_loader
            logger.info(f"工具加载器初始化完成，加载了 {len(tool_loader.tools)} 个工具")
        except Exception as e:
            logger.error(f"工具加载器初始化失败: {e}")
            # 创建空的工具加载器占位符
            class DummyToolLoader:
                tools = {}
                def get_tool(self, name):
                    return None
                def list_tools(self):
                    return []
                def build_command(self, tool_name, params):
                    return ""

            tool_loader = DummyToolLoader()
            app.state.tool_loader = tool_loader
            logger.warning("使用空的工具加载器占位符，工具执行功能受限")

        # 初始化任务队列（无论Docker客户端是否可用，都创建队列以支持CLI回退）
        try:
            task_queue = TaskQueue(redis_client, tool_loader)
            app.state.task_queue = task_queue
            logger.info("任务队列初始化完成（支持CLI回退）")
        except Exception as e:
            logger.error(f"任务队列初始化失败: {e}")
            task_queue = None
            logger.warning("任务队列初始化失败，异步任务处理不可用")

        # 设置应用状态
        app.state.docker_client = docker_client
        app.state.redis_client = redis_client

        app.state.initialized = True

        # 启动后台任务处理器（仅在任务队列可用时）
        background_tasks = BackgroundTasks()
        if task_queue:
            background_tasks.add_task(task_queue.process_tasks)
            logger.info("后台任务处理器已启用")
        else:
            logger.warning("任务队列不可用，后台任务处理器已禁用")
        app.state.background_tasks = background_tasks

        logger.info("工具执行服务初始化完成")

        yield

    except docker.errors.DockerException as e:
        logger.error(f"Docker客户端初始化失败: {e}")
        raise
    except redis.ConnectionError as e:
        logger.error(f"Redis连接失败: {e}")
        raise
    except Exception as e:
        logger.error(f"工具执行服务启动失败: {e}")
        raise

    finally:
        # 关闭时
        logger.info("关闭 ClawAI 工具执行服务...")
        if redis_client:
            redis_client.close()
        app.state.initialized = False


class TaskQueue:
    """任务队列管理器"""

    def __init__(self, redis_client, tool_loader=None):
        self.redis = redis_client
        self.tool_loader = tool_loader
        self.queue_key = "tool_executor:tasks"
        self.processing_key = "tool_executor:processing"
        self.results_key = "tool_executor:results"

    async def add_task(self, task_data: Dict[str, Any]) -> str:
        """添加任务到队列"""
        task_id = str(uuid.uuid4())
        task_data["task_id"] = task_id
        task_data["created_at"] = time.time()
        task_data["status"] = "pending"

        # 存储任务数据
        self.redis.hset(self.results_key, task_id, json.dumps(task_data))
        # 添加到队列
        self.redis.lpush(self.queue_key, task_id)

        logger.info(f"任务添加到队列: {task_id}")
        return task_id

    async def process_tasks(self):
        """处理队列中的任务（后台运行）"""
        logger.info("启动任务处理器...")

        while True:
            try:
                # 更新队列大小指标
                queue_size = self.redis.llen(self.queue_key)
                TASK_QUEUE_SIZE.set(queue_size)

                # 从队列获取任务
                task_id = self.redis.rpop(self.queue_key)

                if not task_id:
                    await asyncio.sleep(1)
                    continue

                # 标记为处理中
                self.redis.hset(self.processing_key, task_id, "processing")

                # 获取任务数据
                task_data_json = self.redis.hget(self.results_key, task_id)
                if not task_data_json:
                    logger.error(f"任务数据不存在: {task_id}")
                    continue

                task_data = json.loads(task_data_json)
                task_data["status"] = "processing"
                task_data["started_at"] = time.time()

                # 更新任务状态
                self.redis.hset(self.results_key, task_id, json.dumps(task_data))

                # 执行任务
                try:
                    result = await self.execute_tool(task_data)
                    task_data["status"] = "completed"
                    task_data["completed_at"] = time.time()
                    task_data["result"] = result
                except Exception as e:
                    logger.error(f"任务执行失败: {task_id}, {e}")
                    task_data["status"] = "failed"
                    task_data["error"] = str(e)
                    task_data["completed_at"] = time.time()

                # 更新最终状态
                self.redis.hset(self.results_key, task_id, json.dumps(task_data))
                # 从处理中移除
                self.redis.hdel(self.processing_key, task_id)

                logger.info(f"任务处理完成: {task_id}, 状态: {task_data['status']}")

            except Exception as e:
                logger.error(f"任务处理器异常: {e}")
                await asyncio.sleep(5)

    async def execute_with_cli_fallback(self, tool_name: str, target: str, parameters: Dict[str, Any]) -> Dict[str, Any]:
        """通过docker CLI执行工具（回退方案）"""
        logger.info(f"使用CLI回退执行工具: {tool_name}, 目标: {target}")

        # 构建基本容器配置
        container_config = {
            "image": "alpine:latest",
            "name": f"clawai-{tool_name}-{uuid.uuid4().hex[:8]}",
            "remove": True,
            "detach": False,  # 直接运行，无需分离
        }

        # 尝试从工具加载器获取配置
        if self.tool_loader:
            tool_config = self.tool_loader.get_tool(tool_name)
            if tool_config:
                if tool_config.container_image:
                    container_config["image"] = tool_config.container_image
                if tool_config.container_options:
                    # 合并选项，但避免冲突字段
                    for key, value in tool_config.container_options.items():
                        if key not in ["name", "remove", "detach"]:
                            container_config[key] = value

        # 构建命令（如果build_tool_command失败，使用简单命令）
        try:
            command = self.build_tool_command(tool_name, target, parameters)
        except Exception as e:
            logger.warning(f"构建命令失败，使用简单命令: {e}")
            command = f"{tool_name} {target}"
            if parameters:
                for key, value in parameters.items():
                    command += f" {key} {value}"

        # 构建docker CLI命令
        docker_cmd = ["docker", "run", "--rm"]

        # 添加容器选项
        if container_config.get("cap_add"):
            for cap in container_config["cap_add"]:
                docker_cmd.extend(["--cap-add", cap])

        if container_config.get("devices"):
            for device in container_config["devices"]:
                docker_cmd.extend(["--device", device])

        if container_config.get("environment"):
            for key, value in container_config["environment"].items():
                docker_cmd.extend(["-e", f"{key}={value}"])

        # 添加镜像和命令
        docker_cmd.append(container_config["image"])
        docker_cmd.append("sh")
        docker_cmd.append("-c")
        docker_cmd.append(command)

        try:
            # 执行命令
            logger.info(f"执行CLI命令: {' '.join(docker_cmd)}")
            result = subprocess.run(
                docker_cmd,
                capture_output=True,
                text=True,
                timeout=parameters.get("timeout", 300),
                check=False
            )

            return {
                "tool": tool_name,
                "target": target,
                "command": command,
                "cli_command": ' '.join(docker_cmd),
                "exit_code": result.returncode,
                "output": result.stdout,
                "error": result.stderr,
                "success": result.returncode == 0,
                "method": "cli_fallback"
            }

        except subprocess.TimeoutExpired:
            logger.error(f"CLI命令执行超时: {tool_name}")
            return {
                "tool": tool_name,
                "target": target,
                "command": command,
                "exit_code": -1,
                "output": "",
                "error": "Command timeout",
                "success": False,
                "method": "cli_fallback"
            }
        except Exception as e:
            logger.error(f"CLI命令执行失败: {e}")
            return {
                "tool": tool_name,
                "target": target,
                "command": command,
                "exit_code": -1,
                "output": "",
                "error": str(e),
                "success": False,
                "method": "cli_fallback"
            }

    async def execute_tool(self, task_data: Dict[str, Any]) -> Dict[str, Any]:
        """执行工具任务"""
        tool_name = task_data.get("tool")
        target = task_data.get("target")
        parameters = task_data.get("parameters", {})

        if not tool_name or not target:
            raise ValueError("缺少工具名称或目标")

        logger.info(f"执行工具: {tool_name}, 目标: {target}")

        # 开始计时
        start_time = time.time()

        try:
            # 尝试使用docker库执行
            result = await self._execute_with_docker_lib(tool_name, target, parameters)

            # 计算处理时间
            processing_time = time.time() - start_time
            TASK_PROCESSING_TIME.labels(tool_name=tool_name).observe(processing_time)

            # 增加成功指标
            TOOL_EXECUTIONS.labels(tool_name=tool_name, status="success").inc()

            return result

        except Exception as e:
            # 检查是否是docker库相关的异常
            is_docker_error = (
                "docker" in str(type(e)).lower() or
                "docker" in str(e).lower() or
                "Not supported URL scheme" in str(e) or
                "http+docker" in str(e)
            )

            if is_docker_error:
                logger.warning(f"Docker库执行失败，切换到CLI回退: {e}")
                try:
                    # 使用CLI回退
                    result = await self.execute_with_cli_fallback(tool_name, target, parameters)

                    # 计算处理时间
                    processing_time = time.time() - start_time
                    TASK_PROCESSING_TIME.labels(tool_name=tool_name).observe(processing_time)

                    # 更新指标为回退成功/失败
                    status = "success" if result.get("success", False) else "failed"
                    TOOL_EXECUTIONS.labels(tool_name=tool_name, status=status).inc()

                    return result
                except Exception as cli_error:
                    logger.error(f"CLI回退也失败: {cli_error}")
                    # 继续抛出原始异常

            # 计算处理时间（即使失败）
            processing_time = time.time() - start_time
            TASK_PROCESSING_TIME.labels(tool_name=tool_name).observe(processing_time)

            # 增加失败指标
            TOOL_EXECUTIONS.labels(tool_name=tool_name, status="failed").inc()
            raise

    async def _execute_with_docker_lib(self, tool_name: str, target: str, parameters: Dict[str, Any]) -> Dict[str, Any]:
        """使用docker库执行工具（内部方法）"""
        # 基于工具配置选择执行方法
        tool_config = None
        if self.tool_loader:
            tool_config = self.tool_loader.get_tool(tool_name)

        if tool_config:
            # 使用配置驱动的执行方法
            if tool_config.requires_container:
                result = await self.execute_security_tool(tool_name, target, parameters)
            else:
                # 对于不需要容器的工具（理论上应该很少）
                result = await self.execute_in_container(tool_name, target, parameters)
        else:
            # 回退到旧逻辑（兼容性）
            logger.warning(f"工具 '{tool_name}' 未找到配置，使用回退执行方法")
            if tool_name in ["nmap", "whatweb", "sqlmap", "nikto", "dirsearch"]:
                result = await self.execute_security_tool(tool_name, target, parameters)
            else:
                # 使用通用容器执行
                result = await self.execute_in_container(tool_name, target, parameters)

        return result

    async def execute_security_tool(self, tool_name: str, target: str, parameters: Dict[str, Any]) -> Dict[str, Any]:
        """执行安全工具（容器化）"""
        # 将目标地址添加到参数中（如果配置需要）
        exec_parameters = parameters.copy()
        exec_parameters["target"] = target

        # 获取安全沙箱配置
        security_level = os.getenv("SANDBOX_SECURITY_LEVEL", "standard").upper()
        try:
            security_level_enum = SandboxSecurityLevel[security_level]
        except KeyError:
            security_level_enum = SandboxSecurityLevel.STANDARD
            logger.warning(f"未知的安全级别: {security_level}，使用标准级别")

        sandbox_config = get_sandbox_config(security_level_enum, tool_name)
        docker_config = sandbox_config.get_docker_config()

        # 基础容器配置
        container_config = {
            "image": "kalilinux/kali-rolling",  # 默认镜像
            "name": f"clawai-{tool_name}-{uuid.uuid4().hex[:8]}",
            "detach": True,
            "tty": True,
        }

        # 合并沙箱配置
        container_config.update(docker_config)

        # 如果有工具加载器，尝试从配置中获取容器设置（覆盖沙箱配置）
        if self.tool_loader:
            tool_config = self.tool_loader.get_tool(tool_name)
            if tool_config:
                if tool_config.container_image:
                    container_config["image"] = tool_config.container_image
                if tool_config.container_options:
                    # 合并容器选项，但避免覆盖关键安全设置
                    safe_keys = ["environment", "volumes", "working_dir", "user"]
                    for key, value in tool_config.container_options.items():
                        if key in safe_keys:
                            container_config[key] = value
                        elif key == "cap_add" and security_level_enum != SandboxSecurityLevel.PARANOID:
                            # 仅在非偏执级别允许添加权限
                            if key not in container_config:
                                container_config[key] = []
                            container_config[key].extend(value)

        # 构建命令
        command = self.build_tool_command(tool_name, target, exec_parameters)

        try:
            # 创建并启动容器
            container = docker_client.containers.run(**container_config)
            # 增加容器创建指标
            CONTAINER_CREATIONS.inc()

            # 执行命令
            exec_result = container.exec_run(
                f"/bin/bash -c {command}",
                stdout=True,
                stderr=True
            )

            # 获取输出
            output = exec_result.output.decode('utf-8').strip()
            exit_code = exec_result.exit_code

            # 停止容器
            container.stop()

            return {
                "tool": tool_name,
                "target": target,
                "command": command,
                "exit_code": exit_code,
                "output": output,
                "success": exit_code == 0
            }

        except Exception as e:
            logger.error(f"容器执行失败: {e}")
            raise

    def build_tool_command(self, tool_name: str, target: str, parameters: Dict[str, Any]) -> str:
        """构建工具命令（完全配置驱动）

        Args:
            tool_name: 工具名称，必须在配置中定义
            target: 目标地址
            parameters: 工具参数

        Returns:
            构建好的命令字符串

        Raises:
            ValueError: 如果工具配置不存在或参数验证失败
        """
        if not self.tool_loader:
            raise ValueError("工具加载器未初始化，无法构建命令")

        # 获取工具配置
        tool_config = self.tool_loader.get_tool(tool_name)
        if not tool_config:
            raise ValueError(f"工具 '{tool_name}' 未在配置中定义")

        # 添加目标到参数中（如果尚未存在）
        if "target" not in parameters:
            parameters["target"] = target

        # 使用工具加载器构建命令
        success, command, error, validated_params = self.tool_loader.validate_and_build_command(
            tool_name, parameters
        )

        if not success:
            logger.error(f"构建命令失败 {tool_name}: {error}")
            raise ValueError(f"参数验证失败: {error}")

        # 确保命令不为空
        if not command.strip():
            command = f"{tool_name} {target}"

        return command

    def _deprecated_legacy_build_command(self, tool_name: str, target: str, parameters: Dict[str, Any]) -> str:
        """已弃用：旧版命令构建逻辑（仅用于兼容性）"""
        import warnings
        warnings.warn(f"_legacy_build_command is deprecated for tool '{tool_name}'. Use YAML configuration instead.",
                     DeprecationWarning, stacklevel=2)

        base_commands = {
            "nmap": f"nmap -sT -sV -sC {target}",
            "whatweb": f"whatweb {target}",
            "sqlmap": f"sqlmap -u {target} --batch --level=1",
            "nikto": f"nikto -h {target}",
            "dirsearch": f"dirsearch -u {target} -e php,asp,aspx,jsp,html"
        }

        command = base_commands.get(tool_name, f"{tool_name} {target}")

        # 添加参数
        if parameters:
            for key, value in parameters.items():
                if key.startswith("-"):
                    command += f" {key} {value}"
                else:
                    command += f" --{key} {value}"

        return command

    async def execute_in_container(self, tool_name: str, target: str, parameters: Dict[str, Any]) -> Dict[str, Any]:
        """在容器中执行通用命令（配置驱动）"""
        try:
            # 构建命令（使用配置驱动）
            command = self.build_tool_command(tool_name, target, parameters)

            # 获取容器配置（从工具配置或使用默认值）
            container_config = {
                "image": "alpine:latest",
                "command": command,
                "remove": True,
                "stdout": True,
                "stderr": True
            }

            # 如果工具配置存在，使用配置中的容器设置
            if self.tool_loader:
                tool_config = self.tool_loader.get_tool(tool_name)
                if tool_config:
                    if tool_config.container_image:
                        container_config["image"] = tool_config.container_image
                    if tool_config.container_options:
                        # 合并容器选项，确保不覆盖必需字段
                        for key, value in tool_config.container_options.items():
                            if key not in ["command", "remove", "stdout", "stderr"]:
                                container_config[key] = value

            # 使用临时容器执行命令
            container = docker_client.containers.run(**container_config)
            # 增加容器创建指标
            CONTAINER_CREATIONS.inc()

            output = container.decode('utf-8').strip() if isinstance(container, bytes) else str(container)

            return {
                "tool": tool_name,
                "target": target,
                "command": command,
                "exit_code": 0,
                "output": output,
                "success": True
            }

        except Exception as e:
            logger.error(f"通用容器执行失败: {e}")
            # 抛出异常以便上层可以切换到CLI回退
            raise

    async def get_task_status(self, task_id: str) -> Optional[Dict[str, Any]]:
        """获取任务状态"""
        task_data_json = self.redis.hget(self.results_key, task_id)
        if not task_data_json:
            return None

        task_data = json.loads(task_data_json)

        # 检查是否在处理中
        if self.redis.hexists(self.processing_key, task_id):
            task_data["status"] = "processing"

        return task_data


# 创建FastAPI应用
app = FastAPI(
    title="ClawAI Tool Executor",
    description="工具执行服务，基于Docker容器化隔离",
    version="1.0.0",
    docs_url="/docs",
    redoc_url="/redoc",
    lifespan=lifespan
)

# 配置CORS
app.add_middleware(
    CORSMiddleware,
    allow_origins=os.getenv("ALLOWED_ORIGINS", "*").split(","),
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)


@app.get("/health")
async def health_check():
    """工具执行服务健康检查"""
    if not hasattr(app.state, "initialized") or not app.state.initialized:
        raise HTTPException(
            status_code=status.HTTP_503_SERVICE_UNAVAILABLE,
            detail="工具执行服务未初始化"
        )

    services_health = {}

    # 检查Docker
    docker_health = 0
    if docker_client is None:
        services_health["docker"] = "unavailable (using CLI fallback)"
    else:
        try:
            docker_client.version()
            services_health["docker"] = "healthy"
            docker_health = 1
        except Exception as e:
            services_health["docker"] = f"unhealthy: {str(e)}"

    # 检查Redis
    redis_health = 0
    try:
        redis_client.ping()
        services_health["redis"] = "healthy"
        redis_health = 1
    except Exception as e:
        services_health["redis"] = f"unhealthy: {str(e)}"

    # 更新健康指标
    SERVICE_HEALTH.labels(service="docker").set(docker_health)
    SERVICE_HEALTH.labels(service="redis").set(redis_health)

    # 总体状态
    overall_status = "healthy"
    for service, status in services_health.items():
        if status != "healthy":
            overall_status = "degraded"

    return {
        "service": "tool-executor",
        "status": overall_status,
        "version": "1.0.0",
        "timestamp": time.time(),
        "services": services_health
    }


@app.get("/api/v1/tools/available")
async def get_available_tools(category: Optional[str] = None):
    """获取可用工具列表"""
    if not hasattr(app.state, "initialized") or not app.state.initialized:
        raise HTTPException(
            status_code=status.HTTP_503_SERVICE_UNAVAILABLE,
            detail="工具执行服务未初始化"
        )

    try:
        tool_loader = app.state.tool_loader
        tools = tool_loader.list_tools(category=category)

        # 添加版本信息（可从配置中扩展）
        for tool in tools:
            # 这里可以从配置中获取版本信息，暂时使用默认值
            tool["version"] = "1.0.0"  # 后续可从配置中读取

        return {
            "tools": tools,
            "count": len(tools),
            "categories": tool_loader.get_categories(),
            "timestamp": time.time()
        }

    except Exception as e:
        logger.error(f"获取工具列表失败: {e}")
        raise HTTPException(
            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
            detail=f"获取工具列表失败: {str(e)}"
        )


@app.post("/api/v1/tools/execute")
async def execute_tool(request_data: Dict[str, Any]):
    """执行工具（异步）"""
    if not hasattr(app.state, "initialized") or not app.state.initialized:
        raise HTTPException(
            status_code=status.HTTP_503_SERVICE_UNAVAILABLE,
            detail="工具执行服务未初始化"
        )

    try:
        tool_name = request_data.get("tool")
        target = request_data.get("target")
        parameters = request_data.get("parameters", {})
        timeout = request_data.get("timeout", 300)  # 默认5分钟

        if not tool_name or not target:
            raise HTTPException(
                status_code=status.HTTP_400_BAD_REQUEST,
                detail="必须提供工具名称和目标地址"
            )

        # 创建任务
        task_data = {
            "tool": tool_name,
            "target": target,
            "parameters": parameters,
            "timeout": timeout,
            "submitted_by": request_data.get("user_id", "anonymous")
        }

        task_queue = app.state.task_queue
        task_id = await task_queue.add_task(task_data)

        logger.info(f"工具执行任务创建: {task_id}, 工具: {tool_name}, 目标: {target}")

        return {
            "task_id": task_id,
            "status": "pending",
            "message": "任务已提交到队列",
            "tool": tool_name,
            "target": target,
            "created_at": time.time()
        }

    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"创建执行任务失败: {e}")
        raise HTTPException(
            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
            detail=f"创建执行任务失败: {str(e)}"
        )


@app.get("/api/v1/tasks/{task_id}")
async def get_task_status(task_id: str):
    """获取任务状态"""
    if not hasattr(app.state, "initialized") or not app.state.initialized:
        raise HTTPException(
            status_code=status.HTTP_503_SERVICE_UNAVAILABLE,
            detail="工具执行服务未初始化"
        )

    try:
        task_queue = app.state.task_queue
        task_data = await task_queue.get_task_status(task_id)

        if not task_data:
            raise HTTPException(
                status_code=status.HTTP_404_NOT_FOUND,
                detail=f"任务 {task_id} 未找到"
            )

        return task_data

    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"获取任务状态失败: {e}")
        raise HTTPException(
            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
            detail=f"获取任务状态失败: {str(e)}"
        )


if __name__ == "__main__":
    import uvicorn

    host = os.getenv("HOST", "0.0.0.0")
    port = int(os.getenv("PORT", "8082"))

    logger.info(f"启动工具执行服务: http://{host}:{port}")
    logger.info(f"API文档: http://{host}:{port}/docs")

    uvicorn.run(
        "main:app",
        host=host,
        port=port,
        reload=os.getenv("ENVIRONMENT", "development") == "development"
    )