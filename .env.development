# ClawAI 开发环境配置
# 本文件可以提交到 git（不包含真实密钥）

# ==================== 基础配置 ====================
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# 开发环境允许本地来源
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ==================== 安全配置 ====================
# 开发环境使用固定密钥（方便调试，不得用于生产）
JWT_SECRET_KEY=dev-jwt-secret-key-not-for-production
SECRET_KEY=dev-secret-key-not-for-production

# 开发环境可以关闭认证（方便测试）
API_AUTH_ENABLED=false
DEBUG=false
RELOAD=true

# ==================== 服务器配置 ====================
SERVER_HOST=0.0.0.0
BACKEND_PORT=8000

# ==================== 数据库配置 ====================
DATABASE_URL=sqlite:///./data/databases/clawai_dev.db

# ==================== 工具配置 ====================
TOOLS_DIR=./tools/penetration
TOOL_TIMEOUT=60

# ==================== 模块配置 ====================
MODULES_CONFIG_PATH=./config/modules.yaml
RBAC_CONFIG_PATH=./config/rbac.json
AUDIT_STORAGE_DIR=./data/audit

# ==================== AI配置 ====================
# 开发时填写本地测试密钥
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
LLM_PROVIDER=deepseek

# ==================== 功能开关 ====================
ENABLE_AI_ANALYSIS=true
ENABLE_TOOL_EXECUTION=true
ENABLE_AUDIT_LOGGING=true
ENABLE_REAL_ATTACK=false

# ==================== Docker开发配置 ====================
POSTGRES_USER=clawai
POSTGRES_PASSWORD=clawai_dev_password
POSTGRES_DB=clawai_dev
REDIS_PASSWORD=clawai_dev_redis

# ==================== Python ====================
PYTHONPATH=./src
