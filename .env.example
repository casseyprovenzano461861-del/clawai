# ClawAI 模块化单体应用环境配置示例
# 复制此文件为 .env 并修改相应值
# 版本: 2.0.0 (模块化单体架构)

# ==================== 基础配置 ====================
# 运行环境: development, testing, production
ENVIRONMENT=development

# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 允许的跨域来源，多个用逗号分隔
ALLOWED_ORIGINS=*

# ==================== 安全配置 ====================
# JWT密钥 (必须修改)
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# 应用密钥 (必须修改)
SECRET_KEY=your-secret-key-change-in-production

# ==================== 服务器配置 ====================
# 服务器绑定地址
SERVER_HOST=0.0.0.0

# 服务器端口
BACKEND_PORT=8000

# ==================== 数据库配置 ====================
# SQLite数据库路径 (默认)
DATABASE_URL=sqlite:///./data/databases/clawai.db

# PostgreSQL数据库示例 (如果需要)
# DATABASE_URL=postgresql://clawai:clawaitest123@localhost:5432/clawai

# ==================== 工具配置 ====================
# 安全工具目录
TOOLS_DIR=./tools/penetration

# 工具执行超时时间（秒）
TOOL_TIMEOUT=300

# ==================== 模块配置 ====================
# 模块配置文件路径
MODULES_CONFIG_PATH=./config/modules.yaml

# RBAC配置文件路径
RBAC_CONFIG_PATH=./config/rbac.json

# 审计日志存储目录
AUDIT_STORAGE_DIR=./data/audit

# ==================== AI配置 ====================
# OpenAI API密钥 (可选)
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic API密钥 (可选)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# DeepSeek API密钥 (可选)
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# 默认LLM提供商: openai, anthropic, deepseek
LLM_PROVIDER=openai

# ==================== 功能开关 ====================
# 启用AI分析
ENABLE_AI_ANALYSIS=true

# 启用工具执行
ENABLE_TOOL_EXECUTION=true

# 启用审计日志
ENABLE_AUDIT_LOGGING=true

# ==================== Docker部署配置 ====================
# 以下配置主要在Docker Compose中使用

# PostgreSQL配置 (Docker部署时使用)
POSTGRES_USER=clawai
POSTGRES_PASSWORD=clawaitest123
POSTGRES_DB=clawai

# Redis配置 (Docker部署时使用)
REDIS_PASSWORD=redispass123

# ==================== 开发配置 ====================
# 调试模式
DEBUG=false

# Python路径
PYTHONPATH=/app/src

# 热重载 (开发模式)
RELOAD=false