# ClawAI 生产环境配置模板
# 复制为 .env.production 并填写真实值
# 生成密钥: python -c "import secrets; print(secrets.token_hex(32))"

# ==================== 基础配置 ====================
ENVIRONMENT=production
LOG_LEVEL=INFO

# 允许的跨域来源（生产环境必须指定具体域名，禁止使用 *）
# 多个域名用逗号分隔
ALLOWED_ORIGINS=https://your-frontend-domain.com

# ==================== 安全配置 ====================
# 必须修改！使用 python -c "import secrets; print(secrets.token_hex(32))" 生成
JWT_SECRET_KEY=CHANGE_ME_GENERATE_STRONG_KEY_32_BYTES_HEX
SECRET_KEY=CHANGE_ME_GENERATE_STRONG_KEY_32_BYTES_HEX

# API认证开关 (生产环境必须为 true)
API_AUTH_ENABLED=true

# 调试模式 (生产环境必须为 false)
DEBUG=false

# 热重载 (生产环境必须为 false)
RELOAD=false

# ==================== 服务器配置 ====================
SERVER_HOST=0.0.0.0
BACKEND_PORT=8000

# ==================== 数据库配置 ====================
# 生产环境推荐使用 PostgreSQL
# DATABASE_URL=postgresql://clawai:STRONG_PASSWORD@db:5432/clawai
# SQLite (仅适用于单机小规模部署)
DATABASE_URL=sqlite:///./data/databases/clawai.db

# ==================== 工具配置 ====================
TOOLS_DIR=./tools/penetration
TOOL_TIMEOUT=300

# ==================== 模块配置 ====================
MODULES_CONFIG_PATH=./config/modules.yaml
RBAC_CONFIG_PATH=./config/rbac.json
AUDIT_STORAGE_DIR=./data/audit

# ==================== AI配置 ====================
# 按需填写，不需要的留空
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# 默认LLM提供商: openai, anthropic, deepseek
LLM_PROVIDER=openai

# ==================== 功能开关 ====================
ENABLE_AI_ANALYSIS=true
ENABLE_TOOL_EXECUTION=true
ENABLE_AUDIT_LOGGING=true

# 真实攻击模式（生产环境谨慎开启）
ENABLE_REAL_ATTACK=false

# ==================== Docker部署配置 ====================
# PostgreSQL配置
POSTGRES_USER=clawai
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD
POSTGRES_DB=clawai

# Redis配置（必须修改）
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

# ==================== Python ====================
PYTHONPATH=/app/src
